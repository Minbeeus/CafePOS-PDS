@page
@model CafePOS.Web.Pages.POS.IndexModel
@{
    ViewData["Title"] = "Màn hình POS - Bán hàng tại quầy";
}

@section Styles {
    <link rel="stylesheet" href="~/css/POS/Index.css" asp-append-version="true" />
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card bg-dark text-light border-secondary shadow">
                <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">MÀN HÌNH POS (BÁN HÀNG)</h5>
                    <span class="badge bg-dark" id="posStaffBadge">Nhân viên</span>
                </div>
                <div class="card-body">
                    <h5 class="card-title">Xác thực thành công!</h5>
                    <p class="card-text text-muted">Bạn đang truy cập hệ thống POS bán hàng dành cho Thu ngân và Trưởng ca.</p>
                    
                    <hr class="border-secondary" />

                    <!-- Test manager PIN verify -->
                    <div class="bg-secondary bg-opacity-10 p-3 rounded border border-secondary mb-3">
                        <h6 class="fw-bold text-warning mb-3">🔑 Test Xác thực mã Trưởng ca (Shift Leader) / Chủ cửa hàng</h6>
                        <p class="small text-muted">API này dùng để duyệt các thao tác giảm giá thủ công (manual discount) trên POS.</p>
                        
                        <div class="input-group mb-3" style="max-width: 400px;">
                            <input type="password" id="managerPinInput" class="form-control bg-dark text-light border-secondary" placeholder="Nhập mã xác thực (Ví dụ: 111111 hoặc 222222)" maxlength="6" />
                            <button class="btn btn-warning" type="button" onclick="testVerifyCode()">Xác nhận mã</button>
                        </div>
                        
                        <div id="verifyResult" class="alert d-none" role="alert"></div>
                    </div>

                    <!-- Token view for senior developer inspection -->
                    <div class="mt-4">
                        <label class="form-label small text-muted">JWT Token hiện tại:</label>
                        <textarea class="form-control bg-black text-success border-secondary font-monospace" style="font-size: 0.75rem;" rows="3" id="jwtTokenDisplay" readonly></textarea>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const API_URL = "http://localhost:5076/api/v1";

        window.addEventListener('DOMContentLoaded', () => {
            const token = localStorage.getItem("token");
            const staffStr = localStorage.getItem("staff");
            
            if (token) {
                document.getElementById("jwtTokenDisplay").value = token;
            }
            if (staffStr) {
                const staff = JSON.parse(staffStr);
                document.getElementById("posStaffBadge").innerText = `${staff.fullName} (${staff.role})`;
            }
        });

        async function testVerifyCode() {
            const pin = document.getElementById("managerPinInput").value;
            const resultDiv = document.getElementById("verifyResult");
            
            if (!pin) {
                resultDiv.className = "alert alert-danger mt-2";
                resultDiv.innerText = "Vui lòng nhập mã PIN cần test.";
                resultDiv.classList.remove("d-none");
                return;
            }

            const token = localStorage.getItem("token");
            
            try {
                const response = await fetch(`${API_URL}/auth/staff/verify-code`, {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({ 
                        posCode: pin,
                        requiredRole: "ShiftLeader" // Test verifying a ShiftLeader action
                    })
                });

                const result = await response.json();

                if (response.ok && result.success) {
                    const data = result.data;
                    if (data.isValid) {
                        resultDiv.className = "alert alert-success mt-2";
                        resultDiv.innerText = `✓ Mã hợp lệ! Xác nhận bởi: ${data.staffName} (${translateRole(data.role)})`;
                    } else {
                        resultDiv.className = "alert alert-warning mt-2";
                        resultDiv.innerText = `✗ Không hợp lệ: ${data.message}`;
                    }
                    resultDiv.classList.remove("d-none");
                } else {
                    resultDiv.className = "alert alert-danger mt-2";
                    resultDiv.innerText = result.message || "Lỗi khi gọi API xác thực.";
                    resultDiv.classList.remove("d-none");
                }
            } catch (err) {
                resultDiv.className = "alert alert-danger mt-2";
                resultDiv.innerText = "Lỗi kết nối máy chủ API.";
                resultDiv.classList.remove("d-none");
                console.error(err);
            }
        }
        
        function translateRole(role) {
            switch(role) {
                case 'Owner': return 'Chủ cửa hàng';
                case 'ShiftLeader': return 'Trưởng ca';
                case 'Cashier': return 'Thu ngân';
                case 'Barista': return 'Pha chế (Bar)';
                case 'PastryStaff': return 'Quầy bánh';
                default: return role;
            }
        }
    </script>
}
