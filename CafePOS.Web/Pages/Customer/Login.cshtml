@page
@model CafePOS.Web.Pages.Customer.LoginModel
@{
    ViewData["Title"] = "Cổng Khách Hàng - Đăng nhập / Đăng ký";
    Layout = null; // Independent customized design
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CafePOS</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Google Identity Services Library -->
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    
    <style>
        :root {
            --primary: #4c7031;         /* Matcha Green */
            --primary-hover: #5c8f3d;   /* Fresh Leaf Green */
            --bg-dark: #120908;         /* Dark Espresso Coffee */
            --card-bg: rgba(43, 27, 24, 0.88); /* Milk Coffee Glass Card */
            --card-border: rgba(244, 234, 225, 0.12); /* Latte Cream Border */
            --text-light: #fefcf9;      /* Whipped Cream White */
            --text-muted: #c8b8b3;      /* Milk Tea Latte Text */
            --glow: rgba(76, 112, 49, 0.25); /* Matcha glow */
            --accent: #ddb892;          /* Honey Sweet Cream */
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: linear-gradient(135deg, #120908 0%, #2a1916 50%, #4c3228 100%);
            color: var(--text-light);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            overflow-x: hidden;
            position: relative;
        }

        /* Ambient light glows in background */
        body::before {
            content: '';
            position: absolute;
            width: 320px;
            height: 320px;
            background: radial-gradient(circle, rgba(76, 112, 49, 0.28) 0%, transparent 70%);
            top: 10%;
            left: 15%;
            z-index: 0;
            pointer-events: none;
        }

        body::after {
            content: '';
            position: absolute;
            width: 380px;
            height: 380px;
            background: radial-gradient(circle, rgba(221, 184, 146, 0.18) 0%, transparent 70%);
            bottom: 10%;
            right: 15%;
            z-index: 0;
            pointer-events: none;
        }

        .login-wrapper {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 480px;
            padding: 20px;
        }

        .brand-section {
            text-align: center;
            margin-bottom: 25px;
        }

        .brand-logo {
            font-size: 2.6rem;
            font-weight: 800;
            background: linear-gradient(to right, var(--accent), #a3b899);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

        .brand-subtitle {
            color: var(--text-muted);
            font-size: 0.95rem;
            font-weight: 300;
        }

        .login-card {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--card-border);
            border-radius: 28px;
            padding: 35px 30px;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.45), 
                        0 0 45px var(--glow);
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .tab-navigation {
            display: flex;
            background: rgba(255, 255, 255, 0.05);
            padding: 5px;
            border-radius: 14px;
            margin-bottom: 25px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .tab-btn {
            flex: 1;
            background: transparent;
            border: none;
            color: var(--text-muted);
            padding: 11px;
            font-weight: 600;
            font-size: 0.92rem;
            border-radius: 10px;
            transition: all 0.2s ease;
            outline: none;
        }

        .tab-btn.active {
            background: var(--primary);
            color: var(--text-light);
            box-shadow: 0 4px 12px var(--glow);
        }

        .form-group {
            margin-bottom: 18px;
        }

        .form-label {
            display: block;
            margin-bottom: 8px;
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.8px;
        }

        .form-control-custom {
            width: 100%;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 12px 16px;
            color: var(--text-light);
            font-size: 0.95rem;
            transition: all 0.3s ease;
            outline: none;
        }

        .form-control-custom:focus {
            border-color: var(--primary);
            box-shadow: 0 0 10px var(--glow);
            background: rgba(255, 255, 255, 0.08);
        }

        .btn-submit {
            width: 100%;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-hover) 100%);
            border: none;
            color: var(--text-light);
            padding: 14px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px var(--glow);
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(76, 112, 49, 0.4);
        }

        .btn-submit:active {
            transform: translateY(0);
        }

        .divider-container {
            display: flex;
            align-items: center;
            margin: 25px 0;
            color: var(--text-muted);
            font-size: 0.85rem;
        }

        .divider-line {
            flex: 1;
            height: 1px;
            background: rgba(255, 255, 255, 0.1);
        }

        .divider-text {
            padding: 0 15px;
            font-weight: 300;
            letter-spacing: 0.5px;
        }

        /* Third party auth section */
        .social-buttons {
            display: flex;
            flex-direction: column;
            gap: 12px;
            align-items: center;
            justify-content: center;
            width: 100%;
        }

        /* Real Google Sign-in button wrapper */
        .g-signin-wrapper {
            display: flex;
            justify-content: center;
            width: 100%;
            height: 44px;
        }

        /* Custom premium mock/demo Google sign-in */
        .btn-social-mock {
            width: 100%;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: var(--text-light);
            border-radius: 12px;
            padding: 11px 16px;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn-social-mock:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(255, 255, 255, 0.2);
            transform: translateY(-1px);
        }

        .btn-social-mock img {
            width: 18px;
            height: 18px;
        }

        .alert-custom {
            background: rgba(239, 68, 68, 0.15);
            border: 1px solid rgba(239, 68, 68, 0.3);
            color: #f87171;
            border-radius: 12px;
            padding: 12px 16px;
            font-size: 0.88rem;
            margin-bottom: 20px;
            display: none;
            animation: shake 0.4s ease-in-out;
        }

        .alert-success-custom {
            background: rgba(16, 185, 129, 0.15);
            border: 1px solid rgba(16, 185, 129, 0.3);
            color: #34d399;
            border-radius: 12px;
            padding: 12px 16px;
            font-size: 0.88rem;
            margin-bottom: 20px;
            display: none;
        }

        @@keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-5px); }
            75% { transform: translateX(5px); }
        }

        /* Success screen overlay for loading */
        .success-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: var(--bg-dark);
            border-radius: 28px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.4s ease;
            z-index: 100;
        }

        .success-overlay.active {
            opacity: 0.98;
            pointer-events: auto;
        }

        .success-spinner {
            width: 50px;
            height: 50px;
            border: 3px solid rgba(255,255,255,0.08);
            border-top: 3px solid var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-bottom: 20px;
        }

        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .success-check {
            width: 70px;
            height: 70px;
            background: rgba(76, 112, 49, 0.15);
            border: 2px solid var(--primary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
            position: relative;
        }

        .success-check svg {
            width: 35px;
            height: 35px;
            stroke: var(--primary);
            stroke-width: 4;
            fill: none;
            stroke-dasharray: 100;
            stroke-dashoffset: 100;
            transition: stroke-dashoffset 0.6s ease 0.2s;
        }

        .success-check.active svg {
            stroke-dashoffset: 0;
        }

        .success-title {
            font-size: 1.25rem;
            font-weight: 600;
            text-align: center;
            margin-top: 10px;
        }

        .help-note {
            text-align: center;
            margin-top: 20px;
            font-size: 0.82rem;
            color: var(--text-muted);
        }

        .help-note strong {
            color: var(--accent);
        }

        .switch-link {
            color: var(--accent);
            cursor: pointer;
            text-decoration: underline;
        }

        .switch-link:hover {
            color: #ffdda1;
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="brand-section">
            <div class="brand-logo">CafePOS</div>
            <div class="brand-subtitle">Cổng đặt hàng trực tuyến cho Khách hàng</div>
        </div>

        <div class="login-card">
            <!-- Loading and Success Overlay -->
            <div class="success-overlay" id="successOverlay">
                <div class="success-spinner" id="successSpinner"></div>
                <div class="success-check" id="successCheck">
                    <svg viewBox="0 0 24 24">
                        <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>
                <div class="success-title" id="successTitle">Đang xử lý...</div>
            </div>

            <!-- Tab Navigation -->
            <div class="tab-navigation">
                <button type="button" class="tab-btn active" id="tabLogin" onclick="switchTab('login')">Đăng nhập</button>
                <button type="button" class="tab-btn" id="tabRegister" onclick="switchTab('register')">Đăng ký</button>
            </div>

            <div class="alert-custom" id="errorAlert"></div>
            <div class="alert-success-custom" id="successAlert"></div>

            <!-- Login Form -->
            <div id="panelLogin">
                <form onsubmit="submitLogin(event)">
                    <div class="form-group">
                        <label class="form-label" for="loginPhone">Số điện thoại</label>
                        <input type="tel" id="loginPhone" class="form-control-custom" placeholder="09xxxxxxxx" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="loginPassword">Mật khẩu</label>
                        <input type="password" id="loginPassword" class="form-control-custom" placeholder="••••••••" required />
                    </div>
                    <button type="submit" class="btn-submit mt-3">Đăng nhập</button>
                </form>
            </div>

            <!-- Register Form -->
            <div id="panelRegister" style="display: none;">
                <form onsubmit="submitRegister(event)">
                    <div class="form-group">
                        <label class="form-label" for="regName">Họ và tên</label>
                        <input type="text" id="regName" class="form-control-custom" placeholder="Nguyễn Văn A" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="regPhone">Số điện thoại</label>
                        <input type="tel" id="regPhone" class="form-control-custom" placeholder="09xxxxxxxx" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="regEmail">Email</label>
                        <input type="email" id="regEmail" class="form-control-custom" placeholder="customer@gmail.com" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="regPassword">Mật khẩu</label>
                        <input type="password" id="regPassword" class="form-control-custom" placeholder="••••••••" required />
                    </div>
                    <button type="submit" class="btn-submit mt-2">Đăng ký tài khoản</button>
                </form>
            </div>

            <div class="divider-container">
                <div class="divider-line"></div>
                <div class="divider-text">hoặc</div>
                <div class="divider-line"></div>
            </div>

            <!-- Third Party Login Options -->
            <div class="social-buttons">
                <!-- Standard Google Authentication Button -->
                <div class="g-signin-wrapper">
                    <!-- Standard GIS Google button placeholder -->
                    <div id="g_id_onload"
                         data-client_id="557721054728-0g2fncq9khmlciuhkrjn5cccdpqpb7un.apps.googleusercontent.com"
                         data-context="signin"
                         data-ux_mode="popup"
                         data-callback="handleCredentialResponse"
                         data-auto_prompt="false">
                    </div>
                    <div class="g_id_signin"
                         data-type="standard"
                         data-shape="rectangular"
                         data-theme="outline"
                         data-text="signin_with"
                         data-size="large"
                         data-logo_alignment="left"
                         style="width: 100%;">
                    </div>
                </div>

                <!-- Fallback/Mock Google sign-in button for instant testing -->
                <button type="button" class="btn-social-mock" onclick="loginWithGoogleDemo()">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" alt="Google Logo" />
                    <span>Đăng nhập Google (Bypass / Demo)</span>
                </button>
            </div>

            <div class="help-note" id="helpNote">
                Chưa có tài khoản? <span class="switch-link" onclick="switchTab('register')">Đăng ký ngay</span>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        const API_URL = "http://localhost:5076/api/v1";

        // Auto redirect if already logged in as Customer
        window.onload = function() {
            const token = localStorage.getItem("token");
            const customerStr = localStorage.getItem("customer");
            const loginMode = localStorage.getItem("loginMode");

            if (token && customerStr && loginMode === "Customer") {
                window.location.href = "/Customer";
            }
        };

        function switchTab(mode) {
            document.getElementById("errorAlert").style.display = "none";
            document.getElementById("successAlert").style.display = "none";
            
            const tabLogin = document.getElementById("tabLogin");
            const tabRegister = document.getElementById("tabRegister");
            const panelLogin = document.getElementById("panelLogin");
            const panelRegister = document.getElementById("panelRegister");
            const helpNote = document.getElementById("helpNote");

            if (mode === 'login') {
                tabLogin.classList.add("active");
                tabRegister.classList.remove("active");
                panelLogin.style.display = "block";
                panelRegister.style.display = "none";
                helpNote.innerHTML = 'Chưa có tài khoản? <span class="switch-link" onclick="switchTab(\'register\')">Đăng ký ngay</span>';
            } else {
                tabLogin.classList.remove("active");
                tabRegister.classList.add("active");
                panelLogin.style.display = "none";
                panelRegister.style.display = "block";
                helpNote.innerHTML = 'Đã có tài khoản? <span class="switch-link" onclick="switchTab(\'login\')">Đăng nhập</span>';
            }
        }

        function showOverlay(title, loading = true, isSuccess = false) {
            const overlay = document.getElementById("successOverlay");
            const spinner = document.getElementById("successSpinner");
            const check = document.getElementById("successCheck");
            const titleEl = document.getElementById("successTitle");

            titleEl.innerText = title;
            overlay.classList.add("active");

            if (loading) {
                spinner.style.display = "block";
                check.style.display = "none";
                check.classList.remove("active");
            } else {
                spinner.style.display = "none";
                check.style.display = "flex";
                if (isSuccess) {
                    check.classList.add("active");
                }
            }
        }

        function hideOverlay() {
            document.getElementById("successOverlay").classList.remove("active");
        }

        function showError(msg) {
            const errorAlert = document.getElementById("errorAlert");
            errorAlert.innerText = msg;
            errorAlert.style.display = "block";
            document.getElementById("successAlert").style.display = "none";
        }

        function showSuccess(msg) {
            const successAlert = document.getElementById("successAlert");
            successAlert.innerText = msg;
            successAlert.style.display = "block";
            document.getElementById("errorAlert").style.display = "none";
        }

        // Submit SĐT / Mật khẩu Login
        async function submitLogin(event) {
            event.preventDefault();
            const phone = document.getElementById("loginPhone").value.trim();
            const password = document.getElementById("loginPassword").value;

            if (!phone || !password) {
                showError("Vui lòng điền số điện thoại và mật khẩu.");
                return;
            }

            showOverlay("Đang đăng nhập...");

            try {
                const response = await fetch(`${API_URL}/auth/customer/login`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ phone: phone, password: password })
                });

                const result = await response.json();

                if (response.ok && result.success) {
                    const data = result.data;
                    localStorage.setItem("token", data.token);
                    localStorage.setItem("customer", JSON.stringify(data.customer));
                    localStorage.setItem("loginMode", "Customer");

                    showOverlay("Đăng nhập thành công!", false, true);

                    setTimeout(() => {
                        window.location.href = "/Customer";
                    }, 1000);
                } else {
                    hideOverlay();
                    showError(result.message || "Đăng nhập thất bại. Vui lòng thử lại.");
                }
            } catch (err) {
                hideOverlay();
                showError("Không thể kết nối đến máy chủ API.");
                console.error(err);
            }
        }

        // Submit SĐT Register
        async function submitRegister(event) {
            event.preventDefault();
            const fullName = document.getElementById("regName").value.trim();
            const phone = document.getElementById("regPhone").value.trim();
            const email = document.getElementById("regEmail").value.trim();
            const password = document.getElementById("regPassword").value;

            if (!fullName || !phone || !email || !password) {
                showError("Vui lòng nhập đầy đủ các thông tin đăng ký.");
                return;
            }

            showOverlay("Đang tạo tài khoản...");

            try {
                const response = await fetch(`${API_URL}/auth/customer/register`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        fullName: fullName,
                        phone: phone,
                        email: email,
                        password: password
                    })
                });

                const result = await response.json();

                if (response.ok && result.success) {
                    const data = result.data;
                    localStorage.setItem("token", data.token);
                    localStorage.setItem("customer", JSON.stringify(data.customer));
                    localStorage.setItem("loginMode", "Customer");

                    showOverlay("Đăng ký thành công!", false, true);

                    setTimeout(() => {
                        window.location.href = "/Customer";
                    }, 1000);
                } else {
                    hideOverlay();
                    showError(result.message || "Đăng ký thất bại. Số điện thoại có thể đã tồn tại.");
                }
            } catch (err) {
                hideOverlay();
                showError("Không thể kết nối đến máy chủ API.");
                console.error(err);
            }
        }

        // Google Authentication Callback
        async function handleCredentialResponse(googleResponse) {
            const idToken = googleResponse.credential;
            showOverlay("Đang xác thực tài khoản Google...");

            try {
                const response = await fetch(`${API_URL}/auth/customer/google-login`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ idToken: idToken, isDemo: false })
                });

                const result = await response.json();

                if (response.ok && result.success) {
                    const data = result.data;
                    localStorage.setItem("token", data.token);
                    localStorage.setItem("customer", JSON.stringify(data.customer));
                    localStorage.setItem("loginMode", "Customer");

                    showOverlay("Kết nối Google thành công!", false, true);

                    setTimeout(() => {
                        window.location.href = "/Customer";
                    }, 1000);
                } else {
                    hideOverlay();
                    showError(result.message || "Xác thực qua Google thất bại.");
                }
            } catch (err) {
                hideOverlay();
                showError("Không thể kết nối đến máy chủ API.");
                console.error(err);
            }
        }

        // Google Authentication Mock/Bypass for testing
        async function loginWithGoogleDemo() {
            showOverlay("Đang xác thực Demo Google...");

            try {
                // Generate a random ID for demo
                const randomId = Math.floor(Math.random() * 1000000);
                const response = await fetch(`${API_URL}/auth/customer/google-login`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        idToken: "", 
                        isDemo: true,
                        demoEmail: `google-user-${randomId}@@gmail.com`,
                        demoName: `Khách Hàng Google #${randomId}`,
                        demoGoogleId: `google-mock-id-${randomId}`
                    })
                });

                const result = await response.json();

                if (response.ok && result.success) {
                    const data = result.data;
                    localStorage.setItem("token", data.token);
                    localStorage.setItem("customer", JSON.stringify(data.customer));
                    localStorage.setItem("loginMode", "Customer");

                    showOverlay("Đăng nhập Demo Google thành công!", false, true);

                    setTimeout(() => {
                        window.location.href = "/Customer";
                    }, 1000);
                } else {
                    hideOverlay();
                    showError(result.message || "Đăng nhập Demo Google thất bại.");
                }
            } catch (err) {
                hideOverlay();
                showError("Không thể kết nối đến máy chủ API.");
                console.error(err);
            }
        }
    </script>
</body>
</html>
