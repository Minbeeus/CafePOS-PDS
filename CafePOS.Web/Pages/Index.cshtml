@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="container py-5 text-center">
    <div class="row justify-content-center mb-5">
        <div class="col-lg-8">
            <h1 class="display-4 fw-bold text-coffee-dark mb-3">☕ Hệ thống CafePOS & PDS</h1>
            <p class="lead text-muted">
                Hệ thống Quản lý Bán hàng tại quầy (POS), Màn hình chế biến (PDS) và Quản trị toàn diện dành cho các quán cà phê và trà sữa hiện đại.
            </p>
        </div>
    </div>

    <!-- Portal Cards Grid -->
    <div class="row g-4 justify-content-center">
        <!-- POS Card -->
        <div class="col-md-4 col-sm-6">
            <div class="card card-custom h-100 hover-card transition-all">
                <div class="card-body d-flex flex-column p-4">
                    <div class="display-5 text-coffee-dark mb-3">🖥️</div>
                    <h4 class="card-title fw-bold text-coffee-dark">Hệ thống POS</h4>
                    <p class="card-text text-muted flex-grow-1 small">Màn hình order và thanh toán tại quầy dành cho Thu ngân & Trưởng ca. Hỗ trợ áp dụng voucher, loyalty.</p>
                    <a href="/POS" class="btn btn-outline-matcha mt-3 w-100 fw-bold">Truy cập POS</a>
                </div>
            </div>
        </div>

        <!-- PDS Card -->
        <div class="col-md-4 col-sm-6">
            <div class="card card-custom h-100 hover-card transition-all">
                <div class="card-body d-flex flex-column p-4">
                    <div class="display-5 text-matcha mb-3">🔌</div>
                    <h4 class="card-title fw-bold text-coffee-dark">Màn hình PDS</h4>
                    <p class="card-text text-muted flex-grow-1 small">Màn hình pha chế thời gian thực tại quầy Barista hoặc bếp Đồ ăn nhẹ. Done đơn hàng nhanh chóng.</p>
                    <a href="/PDS" class="btn btn-outline-matcha mt-3 w-100 fw-bold">Truy cập PDS</a>
                </div>
            </div>
        </div>

        <!-- Admin Card -->
        <div class="col-md-4 col-sm-6">
            <div class="card card-custom h-100 hover-card transition-all">
                <div class="card-body d-flex flex-column p-4">
                    <div class="display-5 text-danger mb-3">📊</div>
                    <h4 class="card-title fw-bold text-coffee-dark">Admin Portal</h4>
                    <p class="card-text text-muted flex-grow-1 small">Trang quản lý dành cho chủ cửa hàng. CRUD thực đơn, quản lý nhân viên, kiểm kho 2 bước và báo cáo doanh thu.</p>
                    <a href="/Admin" class="btn btn-outline-matcha mt-3 w-100 fw-bold">Truy cập Admin</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Credentials Guide Box -->
    <div class="row justify-content-center mt-5">
        <div class="col-lg-8">
            <div class="card card-custom p-4 text-start">
                <h5 class="fw-bold text-coffee-dark mb-3">🔑 Hướng dẫn chạy thử nghiệm & Tài khoản Demo</h5>
                <div class="row text-muted small">
                    <div class="col-md-6">
                        <p class="mb-1"><strong class="text-coffee-dark">Mã khóa đăng nhập nhanh POS (PIN 6 số):</strong></p>
                        <ul class="ps-3 mb-3">
                            <li>Chủ cửa hàng (Owner): <code>111111</code></li>
                            <li>Trưởng ca (ShiftLeader): <code>222222</code></li>
                            <li>Thu ngân (Cashier): <code>333333</code></li>
                            <li>Pha chế (Barista): <code>444444</code></li>
                            <li>Làm bánh (Pastry): <code>555555</code></li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <p class="mb-1"><strong class="text-matcha">Tài khoản Cổng Quản trị Admin:</strong></p>
                        <ul class="ps-3 mb-0">
                            <li>Email: <code>owner@cafepos.com</code></li>
                            <li>Mật khẩu: <code>admin123</code></li>
                        </ul>
                        <p class="mt-3 mb-0 text-matcha"><em>Hệ thống bảo mật sử dụng JWT Token lưu trữ ở client-side và có bộ lọc định hướng phân quyền thông minh.</em></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(78, 54, 41, 0.08) !important;
        border-color: var(--matcha-primary) !important;
    }
</style>
