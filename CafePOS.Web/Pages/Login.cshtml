@page
@model CafePOS.Web.Pages.LoginModel
@{
    ViewData["Title"] = "Đăng nhập hệ thống";
    Layout = null; // Do not use default layout to make it a custom themed login
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CafePOS</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    <style>
        :root {
            --primary: #4c7031;         /* Matcha Green */
            --primary-hover: #5c8f3d;   /* Fresh Leaf Green */
            --bg-dark: #130a09;         /* Espresso Dark */
            --card-bg: rgba(44, 27, 24, 0.85); /* Coffee Brown Card */
            --card-border: rgba(244, 234, 225, 0.12); /* Cream Border */
            --text-light: #fdfaf6;      /* Milk White Text */
            --text-muted: #c6b7b2;      /* Light Latte Text */
            --glow: rgba(76, 112, 49, 0.25); /* Matcha glow */
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: linear-gradient(135deg, #130a09 0%, #2c1b18 50%, #4e3629 100%);
            color: var(--text-light);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            overflow-x: hidden;
            position: relative;
        }

        /* Ambient light glows in background */
        body::before {
            content: '';
            position: absolute;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(76, 112, 49, 0.3) 0%, transparent 70%);
            top: 15%;
            left: 20%;
            z-index: 0;
            pointer-events: none;
        }

        body::after {
            content: '';
            position: absolute;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(221, 184, 146, 0.2) 0%, transparent 70%);
            bottom: 15%;
            right: 15%;
            z-index: 0;
            pointer-events: none;
        }

        .login-wrapper {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 450px;
            padding: 20px;
        }

        .brand-section {
            text-align: center;
            margin-bottom: 25px;
        }

        .brand-logo {
            font-size: 2.5rem;
            font-weight: 800;
            background: linear-gradient(to right, #ddb892, #a3b899);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

        .brand-subtitle {
            color: var(--text-muted);
            font-size: 0.95rem;
            font-weight: 300;
        }

        .login-card {
            background: var(--card-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--card-border);
            border-radius: 24px;
            padding: 35px 30px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 
                        0 0 50px var(--glow);
            transition: all 0.3s ease;
        }

        .tab-navigation {
            display: flex;
            background: rgba(255, 255, 255, 0.05);
            padding: 5px;
            border-radius: 12px;
            margin-bottom: 25px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .tab-btn {
            flex: 1;
            background: transparent;
            border: none;
            color: var(--text-muted);
            padding: 10px;
            font-weight: 600;
            font-size: 0.9rem;
            border-radius: 8px;
            transition: all 0.2s ease;
            outline: none;
        }

        .tab-btn.active {
            background: var(--primary);
            color: var(--text-light);
            box-shadow: 0 4px 12px var(--glow);
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            margin-bottom: 8px;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-control-custom {
            width: 100%;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 12px 16px;
            color: var(--text-light);
            font-size: 0.95rem;
            transition: all 0.3s ease;
            outline: none;
        }

        .form-control-custom:focus {
            border-color: var(--primary);
            box-shadow: 0 0 10px var(--glow);
            background: rgba(255, 255, 255, 0.08);
        }

        .btn-submit {
            width: 100%;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-hover) 100%);
            border: none;
            color: var(--text-light);
            padding: 14px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px var(--glow);
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(76, 112, 49, 0.4);
        }

        .btn-submit:active {
            transform: translateY(0);
        }

        /* Keypad for POS login */
        .pos-display-wrapper {
            position: relative;
            margin-bottom: 20px;
        }

        .pos-code-input {
            width: 100%;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            padding: 15px;
            font-size: 1.8rem;
            font-weight: 800;
            letter-spacing: 6px;
            text-align: center;
            color: #ddb892;
            outline: none;
        }

        .keypad-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-top: 15px;
        }

        .keypad-btn {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.06);
            color: var(--text-light);
            font-size: 1.4rem;
            font-weight: 600;
            padding: 15px 0;
            border-radius: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            outline: none;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .keypad-btn:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(255, 255, 255, 0.2);
            transform: scale(1.05);
        }

        .keypad-btn:active {
            background: var(--primary);
            transform: scale(0.95);
        }

        .keypad-btn.action {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            border-color: rgba(239, 68, 68, 0.2);
        }

        .keypad-btn.action:hover {
            background: #ef4444;
            color: var(--text-light);
        }

        .keypad-btn.ok {
            background: rgba(16, 185, 129, 0.1);
            color: #10b981;
            border-color: rgba(16, 185, 129, 0.2);
        }

        .keypad-btn.ok:hover {
            background: #10b981;
            color: var(--text-light);
        }

        .alert-custom {
            background: rgba(239, 68, 68, 0.15);
            border: 1px solid rgba(239, 68, 68, 0.3);
            color: #f87171;
            border-radius: 12px;
            padding: 12px 16px;
            font-size: 0.88rem;
            margin-bottom: 20px;
            display: none;
            animation: shake 0.4s ease-in-out;
        }

        @@keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-5px); }
            75% { transform: translateX(5px); }
        }

        /* Success screen overlay for loading */
        .success-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: var(--bg-dark);
            border-radius: 24px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.4s ease;
            z-index: 100;
        }

        .success-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }

        .spinner {
            width: 50px;
            height: 50px;
            border: 4px solid rgba(76, 112, 49, 0.1);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-bottom: 20px;
        }

        @@keyframes spin {
            to { transform: rotate(360deg); }
        }

        .success-checkmark {
            width: 60px;
            height: 60px;
            background: #10b981;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: white;
            box-shadow: 0 0 20px rgba(16, 185, 129, 0.4);
            margin-bottom: 20px;
            transform: scale(0);
            transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .success-checkmark.active {
            transform: scale(1);
        }

        .help-note {
            font-size: 0.78rem;
            color: var(--text-muted);
            text-align: center;
            margin-top: 15px;
            line-height: 1.4;
        }
    </style>
</head>
<body>

    <div class="login-wrapper">
        <div class="brand-section">
            <div class="brand-logo">CafePOS & PDS</div>
            <div class="brand-subtitle">Hệ thống quản lý bán hàng & pha chế</div>
        </div>

        <div class="login-card position-relative">
            <!-- Success / Processing screen -->
            <div class="success-overlay" id="successOverlay">
                <div class="spinner" id="successSpinner"></div>
                <div class="success-checkmark" id="successCheck">✓</div>
                <h4 id="successTitle" class="fw-bold">Đang xác thực...</h4>
                <p id="successMsg" class="text-muted text-center px-4">Vui lòng chờ trong giây lát.</p>
            </div>

            <!-- Tab Switcher -->
            <div class="tab-navigation">
                <button class="tab-btn active" id="tabPos" onclick="switchTab('pos')">Mã khóa POS</button>
                <button class="tab-btn" id="tabAdmin" onclick="switchTab('admin')">Quản trị viên</button>
            </div>

            <!-- Error message container -->
            <div class="alert-custom" id="errorAlert">Lỗi đăng nhập</div>

            <!-- POS Login Panel -->
            <div id="panelPos">
                <div class="pos-display-wrapper">
                    <input type="password" class="pos-code-input" id="posCodeInput" readonly placeholder="••••••" maxlength="6" />
                </div>
                <div class="keypad-grid">
                    <button type="button" class="keypad-btn" onclick="pressKey('1')">1</button>
                    <button type="button" class="keypad-btn" onclick="pressKey('2')">2</button>
                    <button type="button" class="keypad-btn" onclick="pressKey('3')">3</button>
                    <button type="button" class="keypad-btn" onclick="pressKey('4')">4</button>
                    <button type="button" class="keypad-btn" onclick="pressKey('5')">5</button>
                    <button type="button" class="keypad-btn" onclick="pressKey('6')">6</button>
                    <button type="button" class="keypad-btn" onclick="pressKey('7')">7</button>
                    <button type="button" class="keypad-btn" onclick="pressKey('8')">8</button>
                    <button type="button" class="keypad-btn" onclick="pressKey('9')">9</button>
                    <button type="button" class="keypad-btn action" onclick="clearKeys()">C</button>
                    <button type="button" class="keypad-btn" onclick="pressKey('0')">0</button>
                    <button type="button" class="keypad-btn ok" onclick="submitPosLogin()">OK</button>
                </div>
                <div class="help-note">
                    Mã mẫu chạy thử:<br/>
                    Owner: <strong>111111</strong> | ShiftLeader: <strong>222222</strong><br/>
                    Cashier: <strong>333333</strong> | Barista: <strong>444444</strong> | Pastry: <strong>555555</strong>
                </div>
            </div>

            <!-- Admin Login Panel -->
            <div id="panelAdmin" style="display: none;">
                <form id="adminLoginForm" onsubmit="submitAdminLogin(event)">
                    <div class="form-group">
                        <label class="form-label" for="adminUsername">Email / Số điện thoại</label>
                        <input type="text" id="adminUsername" class="form-control-custom" placeholder="owner@cafepos.com hoặc 0901234567" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="adminPassword">Mật khẩu</label>
                        <input type="password" id="adminPassword" class="form-control-custom" placeholder="••••••••" required />
                    </div>
                    <button type="submit" class="btn-submit mt-3">Đăng nhập cổng Admin</button>
                </form>
                <div class="help-note">
                    Tài khoản mẫu: <strong>owner@cafepos.com</strong> / <strong>admin123</strong>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        const API_URL = "http://localhost:5076/api/v1";

        // Auto redirect if already logged in
        window.onload = function() {
            const token = localStorage.getItem("token");
            const staffStr = localStorage.getItem("staff");
            const loginMode = localStorage.getItem("loginMode");
            if (token && staffStr && loginMode) {
                try {
                    const staff = JSON.parse(staffStr);
                    if (loginMode === "Admin") {
                        redirectByAdminRole(staff.role);
                    } else {
                        redirectByPosRole(staff.role);
                    }
                } catch (e) {
                    clearStorage();
                }
            }
        };

        function clearStorage() {
            localStorage.removeItem("token");
            localStorage.removeItem("staff");
            localStorage.removeItem("loginMode");
        }

        function switchTab(mode) {
            document.getElementById("errorAlert").style.display = "none";
            if (mode === 'pos') {
                document.getElementById("tabPos").classList.add("active");
                document.getElementById("tabAdmin").classList.remove("active");
                document.getElementById("panelPos").style.display = "block";
                document.getElementById("panelAdmin").style.display = "none";
                clearKeys();
            } else {
                document.getElementById("tabPos").classList.remove("active");
                document.getElementById("tabAdmin").classList.add("active");
                document.getElementById("panelPos").style.display = "none";
                document.getElementById("panelAdmin").style.display = "block";
            }
        }

        // Keypad logic
        let posCode = "";
        const maxDigits = 6;

        function pressKey(num) {
            document.getElementById("errorAlert").style.display = "none";
            if (posCode.length < maxDigits) {
                posCode += num;
                updatePosDisplay();
            }
        }

        function clearKeys() {
            posCode = "";
            updatePosDisplay();
        }

        function updatePosDisplay() {
            const input = document.getElementById("posCodeInput");
            input.value = posCode;
        }

        function showOverlay(title, loading = true, isSuccess = false) {
            const overlay = document.getElementById("successOverlay");
            const spinner = document.getElementById("successSpinner");
            const check = document.getElementById("successCheck");
            const titleEl = document.getElementById("successTitle");

            titleEl.innerText = title;
            overlay.classList.add("active");

            if (loading) {
                spinner.style.display = "block";
                check.style.display = "none";
                check.classList.remove("active");
            } else {
                spinner.style.display = "none";
                check.style.display = "flex";
                if (isSuccess) {
                    check.classList.add("active");
                }
            }
        }

        function hideOverlay() {
            document.getElementById("successOverlay").classList.remove("active");
        }

        function showError(msg) {
            const errorAlert = document.getElementById("errorAlert");
            errorAlert.innerText = msg;
            errorAlert.style.display = "block";
        }

        // Submit POS login (quick code verify)
        async function submitPosLogin() {
            if (posCode.length === 0) {
                showError("Vui lòng nhập mã khóa POS.");
                return;
            }

            showOverlay("Đang xác thực mã POS...");

            try {
                const response = await fetch(`${API_URL}/auth/pos/login`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ posCode: posCode })
                });

                const result = await response.json();

                if (response.ok && result.success) {
                    const data = result.data;
                    localStorage.setItem("token", data.token);
                    localStorage.setItem("staff", JSON.stringify(data.staff));
                    localStorage.setItem("loginMode", "POS");

                    showOverlay("Đăng nhập POS thành công!", false, true);
                    
                    setTimeout(() => {
                        redirectByPosRole(data.staff.role);
                    }, 1000);
                } else {
                    hideOverlay();
                    showError(result.message || "Xác thực mã khóa thất bại.");
                    clearKeys();
                }
            } catch (err) {
                hideOverlay();
                showError("Không thể kết nối đến máy chủ API.");
                console.error(err);
            }
        }

        // Submit Admin Login (username/password)
        async function submitAdminLogin(event) {
            event.preventDefault();
            const usernameInput = document.getElementById("adminUsername").value;
            const passwordInput = document.getElementById("adminPassword").value;

            if (!usernameInput || !passwordInput) {
                showError("Vui lòng nhập đầy đủ thông tin.");
                return;
            }

            showOverlay("Đang xác thực thông tin admin...");

            try {
                const response = await fetch(`${API_URL}/auth/staff/login`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username: usernameInput, password: passwordInput })
                });

                const result = await response.json();

                if (response.ok && result.success) {
                    const data = result.data;
                    const role = data.staff.role;
                    
                    // Strictly enforce that only Owner and ShiftLeader can log in via Admin Portal
                    if (role !== "Owner" && role !== "ShiftLeader") {
                        hideOverlay();
                        showError("Tài khoản của bạn không có quyền truy cập cổng quản trị Admin.");
                        clearStorage();
                        return;
                    }

                    localStorage.setItem("token", data.token);
                    localStorage.setItem("staff", JSON.stringify(data.staff));
                    localStorage.setItem("loginMode", "Admin");

                    showOverlay("Đăng nhập Admin thành công!", false, true);

                    setTimeout(() => {
                        redirectByAdminRole(role);
                    }, 1000);
                } else {
                    hideOverlay();
                    showError(result.message || "Tên đăng nhập hoặc mật khẩu không chính xác.");
                }
            } catch (err) {
                hideOverlay();
                showError("Không thể kết nối đến máy chủ API.");
                console.error(err);
            }
        }

        // Redirection based on role for POS logins (Always routes to worker screens: POS / PDS)
        function redirectByPosRole(role) {
            if (role === "Owner" || role === "ShiftLeader" || role === "Cashier") {
                window.location.href = "/POS";
            } else if (role === "Barista") {
                window.location.href = "/PDS?station=Bar";
            } else if (role === "PastryStaff") {
                window.location.href = "/PDS?station=Pastry";
            } else {
                showError("Tài khoản của bạn không có quyền truy cập hệ thống bán hàng.");
                clearStorage();
            }
        }

        // Redirection based on role for Admin logins (Strictly routes to Admin Dashboard)
        function redirectByAdminRole(role) {
            if (role === "Owner" || role === "ShiftLeader") {
                window.location.href = "/Admin";
            } else {
                showError("Tài khoản của bạn không được cấp quyền quản trị.");
                clearStorage();
            }
        }
    </script>
</body>
</html>
