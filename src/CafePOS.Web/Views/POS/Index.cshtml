@{
    Layout = null;
    ViewData["Title"] = "Màn hình POS - Bán hàng tại quầy";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CafePOS</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pos/Index.css" asp-append-version="true" />
    <!-- Material Symbols -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
</head>
<body>
    <div class="pos-app">
        <!-- Header -->
        <header class="pos-header">
            <div class="header-left">
                <span class="brand-logo">☕</span>
                <span class="brand-name">CafePOS</span>
            </div>
            
            <div class="header-center">
                <!-- Clock -->
                <div class="clock-display" id="clock">00:00:00</div>
                
                <!-- Toggle Serving Type -->
                <div class="serving-toggle">
                    <button class="toggle-btn active" id="btnDineIn" onclick="setServingType('DineIn')">Tại Quầy</button>
                    <button class="toggle-btn" id="btnTakeAway" onclick="setServingType('TakeAway')">Mang Đi</button>
                </div>
                
                <!-- Shift Information -->
                <div id="shiftInfoContainer">
                    <!-- Dynamic Shift Status Badge and button will render here -->
                </div>
            </div>
            
            <div class="header-right">
                <!-- Staff Info -->
                <div class="staff-info">
                    <span class="material-symbols-outlined staff-icon">account_circle</span>
                    <span class="staff-name" id="staffNameDisplay">Nhân viên</span>
                </div>
                
                <!-- Logout Button -->
                <button class="logout-btn" onclick="logout()">Đăng Xuất</button>
            </div>
        </header>

        <!-- Main Workspace -->
        <main class="pos-main">
            <!-- Left Panel: Menu -->
            <section class="menu-section">
                <!-- Search bar -->
                <div class="menu-search-bar">
                    <div class="search-input-wrapper">
                        <span class="material-symbols-outlined search-icon">search</span>
                        <input type="text" class="search-input" id="productSearch" placeholder="Tìm tên món ăn, đồ uống..." oninput="onSearchInput(event)" />
                    </div>
                </div>

                <!-- Category Slider -->
                <div class="category-tabs" id="categoryTabs">
                    <button class="category-tab active" onclick="selectCategory(null)">Tất cả</button>
                    <!-- Categories will load dynamically -->
                </div>

                <!-- Product Card Grid -->
                <div class="products-grid-wrapper">
                    <div class="products-grid" id="productsGrid">
                        <!-- Products will load dynamically -->
                    </div>
                </div>
            </section>

            <!-- Right Panel: Cart -->
            <section class="cart-section">
                <!-- Customer Lookup -->
                <div class="customer-box">
                    <div class="customer-search-group">
                        <input type="text" class="customer-input" id="customerPhoneInput" placeholder="Số điện thoại khách hàng (Loyalty)" maxlength="10" />
                        <button class="btn-lookup" onclick="lookupCustomer()">Tìm</button>
                    </div>
                    <div class="customer-info-row d-none" id="customerDetailsBox">
                        <div>
                            <div class="cust-name" id="custName">Khách Hàng</div>
                            <div class="cust-points" id="custPoints">Điểm: 0 pt</div>
                        </div>
                        <div>
                            <span class="cust-tier none" id="custTier">None</span>
                            <button class="btn-remove-item" style="margin-left: 8px;" onclick="clearCustomer()">✕</button>
                        </div>
                    </div>
                </div>

                <!-- Cart Items List -->
                <div class="cart-items-wrapper" id="cartItemsList">
                    <!-- Empty State -->
                    <div class="cart-empty-state" id="cartEmptyState">
                        <span class="material-symbols-outlined cart-empty-icon">shopping_cart</span>
                        <p>Giỏ hàng trống. Chọn sản phẩm để bắt đầu.</p>
                    </div>
                </div>

                <!-- Billing Summary -->
                <div class="cart-summary">
                    <!-- Voucher Input -->
                    <div class="voucher-input-group">
                        <input type="text" class="voucher-input" id="voucherInput" placeholder="Nhập mã voucher (SUMMER10...)" />
                        <button class="btn-apply-voucher" onclick="applyVoucher()">Áp Dụng</button>
                    </div>

                    <!-- Manual Discount Button & Detail -->
                    <div class="manual-discount-row">
                        <div>
                            <span class="discount-label">Giảm giá quản lý:</span>
                            <span class="discount-value" id="manualDiscountDisplay">0%</span>
                        </div>
                        <button class="btn-trigger-discount" onclick="openSupervisorModal()">Giảm Giá</button>
                    </div>

                    <!-- Billing Rows -->
                    <div class="billing-details">
                        <div class="bill-row">
                            <span>Tạm tính</span>
                            <span id="billSubtotal">0đ</span>
                        </div>
                        <div class="bill-row">
                            <span>Giảm giá thành viên</span>
                            <span id="billLoyaltyDiscount">-0đ</span>
                        </div>
                        <div class="bill-row">
                            <span>Giảm giá voucher</span>
                            <span id="billVoucherDiscount">-0đ</span>
                        </div>
                        <div class="bill-row">
                            <span>Giảm giá thủ công</span>
                            <span id="billManualDiscount">-0đ</span>
                        </div>
                        <div class="bill-row grand-total">
                            <span>Tổng thanh toán</span>
                            <span class="val" id="billGrandTotal">0đ</span>
                        </div>
                    </div>

                    <!-- Order Action Buttons -->
                    <div class="cart-actions">
                        <button class="btn-cancel-order" onclick="clearCart()">HỦY ĐƠN</button>
                        <button class="btn-checkout" onclick="handleCheckout()">THANH TOÁN</button>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <!-- Modals -->

    <!-- Open Shift Modal -->
    <div class="modal-overlay" id="openShiftModal">
        <div class="modal-container" style="max-width: 400px;">
            <div class="modal-header">
                <h3 class="modal-title">Bắt Đầu Ca Làm Việc</h3>
            </div>
            <div class="modal-body">
                <div class="modal-section-title">Tiền mặt bàn giao đầu ca (VND)</div>
                <input type="number" class="customer-input" id="openingCashInput" value="1000000" style="width: 100%; font-size: 18px; text-align: right; font-weight: bold; margin-bottom: 12px;" />
                <div class="cash-helpers" style="grid-template-columns: repeat(3, 1fr); gap: 6px;">
                    <button class="cash-helper-btn" onclick="setOpeningCash(500000)">500K</button>
                    <button class="cash-helper-btn" onclick="setOpeningCash(1000000)">1M</button>
                    <button class="cash-helper-btn" onclick="setOpeningCash(2000000)">2M</button>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-primary" onclick="submitOpenShift()" style="width: 100%;">MỞ CA LÀM VIỆC</button>
            </div>
        </div>
    </div>

    <!-- Close Shift Modal -->
    <div class="modal-overlay" id="closeShiftModal">
        <div class="modal-container" style="max-width: 440px;">
            <div class="modal-header">
                <h3 class="modal-title">Kết Thúc Ca Làm Việc</h3>
                <button class="modal-close" onclick="closeModal('closeShiftModal')">✕</button>
            </div>
            <div class="modal-body">
                <div class="modal-section-title">Thực tế đếm được cuối ca</div>
                
                <label class="discount-label" style="display:block; margin-bottom:4px;">Tiền mặt thực tế đếm được (VND)</label>
                <input type="number" class="customer-input" id="actualCashInput" placeholder="Nhập số tiền mặt thực tế" style="width: 100%; font-size: 16px; margin-bottom: 12px;" />
                
                <label class="discount-label" style="display:block; margin-bottom:4px;">Chuyển khoản thực tế khớp được (VND)</label>
                <input type="number" class="customer-input" id="actualTransferInput" placeholder="Nhập số tiền chuyển khoản thực tế" style="width: 100%; font-size: 16px; margin-bottom: 12px;" />
                
                <label class="discount-label" style="display:block; margin-bottom:4px;">Ghi chú bàn giao</label>
                <textarea class="modal-textarea" id="closeShiftNotes" placeholder="Nhập ghi chú bàn giao (ví dụ chênh lệch, lý do...)" rows="2" style="margin-bottom:0;"></textarea>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeModal('closeShiftModal')">BỎ QUA</button>
                <button class="btn-danger-confirm" onclick="submitCloseShift()">ĐÓNG CA & BÀN GIAO</button>
            </div>
        </div>
    </div>

    <!-- Product Customization Modal -->
    <div class="modal-overlay" id="customizationModal">
        <div class="modal-container">
            <div class="modal-header">
                <h3 class="modal-title" id="custModalTitle">Tùy Chọn Món</h3>
                <button class="modal-close" onclick="closeModal('customizationModal')">✕</button>
            </div>
            <div class="modal-body">
                <!-- Size Options -->
                <div id="sizeSection" class="d-none">
                    <div class="modal-section-title">Chọn Size</div>
                    <div class="option-grid-3" id="sizeOptionsList">
                        <!-- Loaded dynamically -->
                    </div>
                </div>

                <!-- Sugar Level Options -->
                <div id="sugarSection" class="d-none">
                    <div class="modal-section-title">Chọn Đường</div>
                    <div class="option-grid-3">
                        <label class="selectable-option">
                            <input type="radio" name="sugarLevel" value="100" checked />
                            <span class="option-card"><span class="option-label">100% đường</span></span>
                        </label>
                        <label class="selectable-option">
                            <input type="radio" name="sugarLevel" value="70" />
                            <span class="option-card"><span class="option-label">70% đường</span></span>
                        </label>
                        <label class="selectable-option">
                            <input type="radio" name="sugarLevel" value="50" />
                            <span class="option-card"><span class="option-label">50% đường</span></span>
                        </label>
                        <label class="selectable-option">
                            <input type="radio" name="sugarLevel" value="30" />
                            <span class="option-card"><span class="option-label">30% đường</span></span>
                        </label>
                        <label class="selectable-option">
                            <input type="radio" name="sugarLevel" value="0" />
                            <span class="option-card"><span class="option-label">0% đường</span></span>
                        </label>
                    </div>
                </div>

                <!-- Ice Level Options -->
                <div id="iceSection" class="d-none">
                    <div class="modal-section-title">Chọn Đá</div>
                    <div class="option-grid-3">
                        <label class="selectable-option">
                            <input type="radio" name="iceLevel" value="100" checked />
                            <span class="option-card"><span class="option-label">100% đá</span></span>
                        </label>
                        <label class="selectable-option">
                            <input type="radio" name="iceLevel" value="70" />
                            <span class="option-card"><span class="option-label">70% đá</span></span>
                        </label>
                        <label class="selectable-option">
                            <input type="radio" name="iceLevel" value="50" />
                            <span class="option-card"><span class="option-label">50% đá</span></span>
                        </label>
                        <label class="selectable-option">
                            <input type="radio" name="iceLevel" value="30" />
                            <span class="option-card"><span class="option-label">30% đá</span></span>
                        </label>
                        <label class="selectable-option">
                            <input type="radio" name="iceLevel" value="0" />
                            <span class="option-card"><span class="option-label">0% đá</span></span>
                        </label>
                    </div>
                </div>

                <!-- Toppings -->
                <div id="toppingsSection" class="d-none">
                    <div class="modal-section-title">Topping Thêm</div>
                    <div class="topping-option-list" id="toppingsOptionsList">
                        <!-- Loaded dynamically -->
                    </div>
                </div>

                <!-- Quantity and Redeem points -->
                <div class="modal-section-title">Số Lượng & Điểm Đổi</div>
                
                <!-- Point redeem row (if eligible) -->
                <div class="points-redeem-row d-none" id="pointRedeemRow">
                    <label class="redeem-checkbox-wrapper">
                        <input type="checkbox" class="redeem-checkbox" id="pointRedeemCheckbox" onchange="togglePointRedemption()" />
                        <span>Đổi sản phẩm bằng 50 điểm</span>
                    </label>
                    <span class="cust-points" style="font-weight:700;">-50 pt</span>
                </div>

                <div class="stepper-row">
                    <div class="stepper-label-wrapper">
                        <span class="stepper-label">Chọn số lượng</span>
                        <span class="stepper-sublabel" id="liveUnitPrice">Đơn giá: 0đ</span>
                    </div>
                    <div class="qty-stepper">
                        <button class="stepper-btn" onclick="changeModalQty(-1)">-</button>
                        <span class="stepper-val" id="modalQtyDisplay">1</span>
                        <button class="stepper-btn" onclick="changeModalQty(1)">+</button>
                    </div>
                </div>

                <!-- Special Notes -->
                <div class="modal-section-title">Ghi Chú Đặc Biệt</div>
                <textarea class="modal-textarea" id="modalNotes" placeholder="Ví dụ: Ít ngọt, nhiều sữa, không đá..." rows="2"></textarea>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeModal('customizationModal')">HỦY BỎ</button>
                <button class="btn-primary" onclick="submitCustomization()" id="btnSaveCustomization">THÊM VÀO GIỎ - 0đ</button>
            </div>
        </div>
    </div>

    <!-- Checkout Modal -->
    <div class="modal-overlay" id="checkoutModal">
        <div class="modal-container">
            <div class="modal-header">
                <h3 class="modal-title">Thanh Toán Đơn Hàng</h3>
                <button class="modal-close" onclick="closeModal('checkoutModal')">✕</button>
            </div>
            <div class="modal-body" style="padding-bottom:12px;">
                <!-- Payment methods -->
                <div class="modal-section-title">Phương thức thanh toán</div>
                <div class="pay-methods-grid">
                    <label class="selectable-option">
                        <input type="radio" name="payMethod" value="Cash" checked onchange="togglePayMethod('Cash')" />
                        <span class="pay-method-card">
                            <span class="pay-method-icon">💵</span>
                            <span>Tiền mặt</span>
                        </span>
                    </label>
                    <label class="selectable-option">
                        <input type="radio" name="payMethod" value="Transfer" onchange="togglePayMethod('Transfer')" />
                        <span class="pay-method-card">
                            <span class="pay-method-icon">📱</span>
                            <span>Chuyển khoản</span>
                        </span>
                    </label>
                    <label class="selectable-option">
                        <input type="radio" name="payMethod" value="Mixed" onchange="togglePayMethod('Mixed')" />
                        <span class="pay-method-card">
                            <span class="pay-method-icon">🔄</span>
                            <span>Hỗn hợp</span>
                        </span>
                    </label>
                </div>

                <!-- Cash details -->
                <div id="cashDetailsBox">
                    <div class="modal-section-title">Tiền nhận của khách (VND)</div>
                    <input type="number" class="customer-input" id="cashReceivedInput" placeholder="Nhập số tiền khách đưa" style="width:100%; font-size: 20px; font-weight:800; text-align:right; margin-bottom:10px;" oninput="onCashReceivedInput()" />
                    <div class="cash-helpers">
                        <button class="cash-helper-btn" onclick="addHelperCash(0)">Exact</button>
                        <button class="cash-helper-btn" onclick="addHelperCash(50000)">50K</button>
                        <button class="cash-helper-btn" onclick="addHelperCash(100000)">100K</button>
                        <button class="cash-helper-btn" onclick="addHelperCash(200000)">200K</button>
                        <button class="cash-helper-btn" onclick="addHelperCash(500000)">500K</button>
                    </div>
                </div>

                <!-- Mixed details -->
                <div id="mixedDetailsBox" class="d-none" style="margin-top:16px;">
                    <div class="modal-section-title">Phân chia thanh toán</div>
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:12px;">
                        <div>
                            <label class="discount-label" style="display:block; margin-bottom:4px;">Khách đưa Tiền mặt</label>
                            <input type="number" class="customer-input" id="mixedCashInput" placeholder="Tiền mặt" style="width:100%; font-size:15px;" oninput="onMixedAmountsInput()" />
                        </div>
                        <div>
                            <label class="discount-label" style="display:block; margin-bottom:4px;">Chuyển khoản QR</label>
                            <input type="number" class="customer-input" id="mixedTransferInput" placeholder="Chuyển khoản" style="width:100%; font-size:15px;" readonly />
                        </div>
                    </div>
                </div>

                <!-- VietQR details -->
                <div id="transferDetailsBox" class="d-none" style="margin-top:16px;">
                    <div class="vietqr-box">
                        <div class="qr-placeholder">
                            <img id="vietqrImage" src="" alt="VietQR Code" class="qr-image-placeholder" />
                        </div>
                        <div class="qr-info">
                            <div class="qr-bank">Ngân hàng MB Bank (Nguyễn Manager)</div>
                            <div class="qr-amount" id="qrAmountDisplay">0đ</div>
                            <div class="qr-content" id="qrContentDisplay">ORD12345</div>
                        </div>
                    </div>
                </div>

                <!-- Checkout summaries -->
                <div class="checkout-details" style="margin-top:16px;">
                    <div class="check-row highlight">
                        <span>Cần thanh toán</span>
                        <span id="checkTotal">0đ</span>
                    </div>
                    <div class="check-row" id="checkCashReceivedRow">
                        <span>Tiền khách đưa</span>
                        <span id="checkReceived">0đ</span>
                    </div>
                    <div class="check-row change" id="checkChangeRow">
                        <span>Tiền thối lại</span>
                        <span id="checkChange">0đ</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeModal('checkoutModal')">QUAY LẠI</button>
                <button class="btn-primary" onclick="submitPayment()" id="btnConfirmPayment">XÁC NHẬN THANH TOÁN</button>
            </div>
        </div>
    </div>

    <!-- Supervisor Auth PIN Modal -->
    <div class="modal-overlay" id="supervisorModal">
        <div class="modal-container" style="max-width: 380px;">
            <div class="modal-header">
                <h3 class="modal-title">🔐 Phê Duyệt Của Trưởng Ca</h3>
                <button class="modal-close" onclick="closeModal('supervisorModal')">✕</button>
            </div>
            <div class="modal-body">
                <div class="modal-section-title">Chọn % Giảm Giá</div>
                <div class="option-grid-3" style="grid-template-columns: repeat(5, 1fr); gap:6px; margin-bottom:16px;">
                    <label class="selectable-option">
                        <input type="radio" name="discountPercentOpt" value="5" />
                        <span class="option-card" style="padding: 8px 4px;">5%</span>
                    </label>
                    <label class="selectable-option">
                        <input type="radio" name="discountPercentOpt" value="10" />
                        <span class="option-card" style="padding: 8px 4px;">10%</span>
                    </label>
                    <label class="selectable-option">
                        <input type="radio" name="discountPercentOpt" value="15" />
                        <span class="option-card" style="padding: 8px 4px;">15%</span>
                    </label>
                    <label class="selectable-option">
                        <input type="radio" name="discountPercentOpt" value="20" checked />
                        <span class="option-card" style="padding: 8px 4px;">20%</span>
                    </label>
                    <label class="selectable-option">
                        <input type="radio" name="discountPercentOpt" value="50" />
                        <span class="option-card" style="padding: 8px 4px;">50%</span>
                    </label>
                </div>

                <div class="modal-section-title">Nhập mã PIN 6 số Quản lý</div>
                <div class="pinpad-display" id="pinDisplay">••••••</div>
                
                <div class="pinpad-grid">
                    <button class="pinpad-btn" onclick="pressPin('1')">1</button>
                    <button class="pinpad-btn" onclick="pressPin('2')">2</button>
                    <button class="pinpad-btn" onclick="pressPin('3')">3</button>
                    <button class="pinpad-btn" onclick="pressPin('4')">4</button>
                    <button class="pinpad-btn" onclick="pressPin('5')">5</button>
                    <button class="pinpad-btn" onclick="pressPin('6')">6</button>
                    <button class="pinpad-btn" onclick="pressPin('7')">7</button>
                    <button class="pinpad-btn" onclick="pressPin('8')">8</button>
                    <button class="pinpad-btn" onclick="pressPin('9')">9</button>
                    <button class="pinpad-btn action-c" onclick="clearPin()">C</button>
                    <button class="pinpad-btn" onclick="pressPin('0')">0</button>
                    <button class="pinpad-btn" onclick="submitSupervisorAuth()" style="background:var(--matcha-primary); color:white;">OK</button>
                </div>

                <div style="margin-top: 14px;">
                    <label class="discount-label" style="display:block; margin-bottom:4px;">Ghi chú phê duyệt</label>
                    <input type="text" class="customer-input" id="approverNoteInput" placeholder="Ví dụ: Khách quen VIP, bù đơn..." style="width:100%; font-size:13px;" />
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Notification Container -->
    <div class="toast-container" id="toastContainer"></div>

    <!-- JavaScript integration -->
    <script>
        const API_URL = "http://localhost:5076/api/v1";
        
        // App states
        let products = [];
        let categories = [];
        let cart = [];
        let currentCategory = null;
        let searchQuery = "";
        let servingType = "DineIn";
        let activeCustomer = null;
        let activeVoucher = null;
        let manualDiscount = { percent: 0, approverCode: null, approverNote: null };
        let activeShift = null;
        
        // Active Customization State
        let editingProduct = null;
        let modalQty = 1;
        let selectedSize = null;
        
        // Active Supervisor State
        let supervisorPin = "";
        
        // Active Checkout Order details (holds DB draft)
        let activeDraftOrder = null;

        // Initialization
        window.addEventListener('DOMContentLoaded', async () => {
            // Check auth
            const token = localStorage.getItem("token");
            const staffStr = localStorage.getItem("staff");
            const loginMode = localStorage.getItem("loginMode");
            
            if (!token || !staffStr || loginMode !== "POS") {
                window.location.href = "/POS/Login";
                return;
            }

            const staff = JSON.parse(staffStr);
            document.getElementById("staffNameDisplay").innerText = `${staff.fullName} (${translateRole(staff.role)})`;

            // Start running clock
            startClock();

            // Fetch active shift details
            await checkShiftStatus();

            // Fetch base data
            await fetchCategories();
            await fetchProducts();
        });

        // Running Clock
        function startClock() {
            const clockEl = document.getElementById("clock");
            setInterval(() => {
                const now = new Date();
                clockEl.innerText = now.toLocaleTimeString('vi-VN');
            }, 1000);
        }

        // Shift Status Check
        async function checkShiftStatus() {
            const token = localStorage.getItem("token");
            try {
                const res = await fetch(`${API_URL}/shifts/active`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const result = await res.json();
                
                if (res.ok && result.success) {
                    activeShift = result.data;
                    renderShiftControls();
                } else {
                    showToast("Lỗi khi kiểm tra ca làm việc.", "error");
                }
            } catch (err) {
                console.error(err);
                showToast("Không kết nối được máy chủ để kiểm tra ca.", "error");
            }
        }

        function renderShiftControls() {
            const container = document.getElementById("shiftInfoContainer");
            if (activeShift) {
                container.innerHTML = `
                    <div style="display:flex; align-items:center; gap:8px;">
                        <span class="cust-tier gold" style="font-size:11px; background:var(--matcha-primary); color:white;">Ca Đang Mở (#${activeShift.id})</span>
                        <button class="btn-trigger-discount" style="border-color:#ff6b57; color:#ff6b57;" onclick="openCloseShiftModal()">Đóng Ca</button>
                    </div>
                `;
            } else {
                container.innerHTML = `
                    <div style="display:flex; align-items:center; gap:8px;">
                        <span class="cust-tier none" style="font-size:11px;">⚠️ Ca Đang Đóng</span>
                        <button class="btn-trigger-discount" style="border-color:var(--matcha-light); color:var(--matcha-light);" onclick="openModal('openShiftModal')">Mở Ca</button>
                    </div>
                `;
            }
        }

        // Open Shift
        function setOpeningCash(val) {
            document.getElementById("openingCashInput").value = val;
        }

        async function submitOpenShift() {
            const token = localStorage.getItem("token");
            const cash = parseFloat(document.getElementById("openingCashInput").value);
            if (isNaN(cash) || cash < 0) {
                showToast("Số tiền không hợp lệ.", "error");
                return;
            }

            try {
                const res = await fetch(`${API_URL}/shifts/open`, {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({ openingCash: cash })
                });
                const result = await res.json();

                if (res.ok && result.success) {
                    showToast("Mở ca thành công!", "success");
                    closeModal("openShiftModal");
                    await checkShiftStatus();
                } else {
                    showToast(result.message || "Không thể mở ca.", "error");
                }
            } catch (err) {
                console.error(err);
                showToast("Lỗi máy chủ khi mở ca.", "error");
            }
        }

        // Close Shift
        function openCloseShiftModal() {
            // Pre-fill or empty inputs
            document.getElementById("actualCashInput").value = "";
            document.getElementById("actualTransferInput").value = "";
            document.getElementById("closeShiftNotes").value = "";
            openModal("closeShiftModal");
        }

        async function submitCloseShift() {
            const token = localStorage.getItem("token");
            const actualCash = parseFloat(document.getElementById("actualCashInput").value);
            const actualTransfer = parseFloat(document.getElementById("actualTransferInput").value);
            const notes = document.getElementById("closeShiftNotes").value;

            if (isNaN(actualCash) || actualCash < 0 || isNaN(actualTransfer) || actualTransfer < 0) {
                showToast("Vui lòng nhập đầy đủ số tiền mặt và chuyển khoản thực tế.", "error");
                return;
            }

            try {
                const res = await fetch(`${API_URL}/shifts/close`, {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({
                        actualCash: actualCash,
                        actualTransfer: actualTransfer,
                        notes: notes
                    })
                });
                const result = await res.json();

                if (res.ok && result.success) {
                    showToast("Đóng ca và bàn giao thành công!", "success");
                    closeModal("closeShiftModal");
                    await checkShiftStatus();
                } else {
                    showToast(result.message || "Không thể đóng ca.", "error");
                }
            } catch (err) {
                console.error(err);
                showToast("Lỗi máy chủ khi đóng ca.", "error");
            }
        }

        // Fetch Categories
        async function fetchCategories() {
            try {
                const res = await fetch(`${API_URL}/products/categories`);
                const result = await res.json();
                if (res.ok && result.success) {
                    categories = result.data.filter(c => c.isActive);
                    renderCategories();
                }
            } catch (err) {
                console.error("Lỗi khi tải danh mục", err);
            }
        }

        // Fetch Products
        async function fetchProducts() {
            try {
                const res = await fetch(`${API_URL}/products`);
                const result = await res.json();
                if (res.ok && result.success) {
                    products = result.data;
                    renderProducts();
                }
            } catch (err) {
                console.error("Lỗi khi tải sản phẩm", err);
            }
        }

        // Render Categories
        function renderCategories() {
            const container = document.getElementById("categoryTabs");
            container.innerHTML = `<button class="category-tab ${currentCategory === null ? 'active' : ''}" onclick="selectCategory(null)">Tất cả</button>`;
            
            categories.forEach(cat => {
                container.innerHTML += `
                    <button class="category-tab ${currentCategory === cat.id ? 'active' : ''}" onclick="selectCategory(${cat.id})">${cat.name}</button>
                `;
            });
        }

        function selectCategory(id) {
            currentCategory = id;
            renderCategories();
            renderProducts();
        }

        // Search Input filter
        function onSearchInput(e) {
            searchQuery = e.target.value;
            renderProducts();
        }

        // Render Products Grid
        function renderProducts() {
            const grid = document.getElementById("productsGrid");
            grid.innerHTML = "";

            const filtered = products.filter(p => {
                const matchCategory = currentCategory === null || p.categoryId === currentCategory;
                const matchQuery = p.name.toLowerCase().includes(searchQuery.toLowerCase()) || 
                                   (p.description && p.description.toLowerCase().includes(searchQuery.toLowerCase()));
                return matchCategory && matchQuery;
            });

            if (filtered.length === 0) {
                grid.innerHTML = `<div style="grid-column: 1/-1; text-align: center; padding: 40px; color: var(--pos-muted);">Không tìm thấy sản phẩm phù hợp.</div>`;
                return;
            }

            filtered.forEach(p => {
                const isOutOfStock = p.status === "OutOfStock";
                
                grid.innerHTML += `
                    <div class="product-card ${isOutOfStock ? 'disabled' : ''}" onclick="onProductCardClick(${p.id})">
                        <div class="product-image-container">
                            ${p.imageUrl ? 
                                `<img src="${p.imageUrl}" alt="${p.name}" class="product-image" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
                                 <span class="material-symbols-outlined product-placeholder-icon" style="display:none;">local_cafe</span>` : 
                                `<span class="material-symbols-outlined product-placeholder-icon">local_cafe</span>`
                            }
                            ${isOutOfStock ? `<span class="product-badge-outofstock">Hết hàng</span>` : ''}
                        </div>
                        <div class="product-info">
                            <h4 class="product-name">${p.name}</h4>
                            <p class="product-desc">${p.description || ''}</p>
                            <div class="product-footer">
                                <span class="product-price">${formatVND(p.basePrice)}</span>
                                <button class="product-add-btn" type="button" ${isOutOfStock ? 'disabled' : ''}>+</button>
                            </div>
                        </div>
                    </div>
                `;
            });
        }

        // Handle card click
        function onProductCardClick(productId) {
            const p = products.find(prod => prod.id === productId);
            if (!p || p.status === "OutOfStock") return;

            // Check if product requires customization options
            if (p.hasSizeOption || p.hasSugarOption || p.hasIceOption || (p.toppings && p.toppings.length > 0)) {
                openCustomizationModal(p);
            } else {
                // Quick add with default values
                const defaultSz = p.sizes && p.sizes.find(s => s.isDefault) || { sizeLabel: "Regular", priceModifier: 0 };
                addToCart({
                    product: p,
                    quantity: 1,
                    size: defaultSz,
                    sugar: "100",
                    ice: "100",
                    toppings: [],
                    notes: "",
                    isPointRedemption: false
                });
            }
        }

        // Customization Modal Logic
        function openCustomizationModal(product) {
            editingProduct = product;
            modalQty = 1;

            document.getElementById("custModalTitle").innerText = product.name;
            document.getElementById("modalQtyDisplay").innerText = "1";
            document.getElementById("modalNotes").value = "";

            // Render sizes
            const sizeSection = document.getElementById("sizeSection");
            const sizeList = document.getElementById("sizeOptionsList");
            if (product.hasSizeOption && product.sizes && product.sizes.length > 0) {
                sizeSection.classList.remove("d-none");
                sizeList.innerHTML = "";
                product.sizes.forEach((s, idx) => {
                    sizeList.innerHTML += `
                        <label class="selectable-option">
                            <input type="radio" name="sizeOption" value="${s.id}" ${s.isDefault ? 'checked' : ''} onchange="updateLivePrice()" />
                            <span class="option-card">
                                <span class="option-label">Size ${s.sizeLabel}</span>
                                <span class="option-price">+${formatVND(s.priceModifier)}</span>
                            </span>
                        </label>
                    `;
                });
            } else {
                sizeSection.classList.add("d-none");
                sizeList.innerHTML = "";
            }

            // Sugar options
            const sugarSection = document.getElementById("sugarSection");
            if (product.hasSugarOption) {
                sugarSection.classList.remove("d-none");
            } else {
                sugarSection.classList.add("d-none");
            }

            // Ice options
            const iceSection = document.getElementById("iceSection");
            if (product.hasIceOption) {
                iceSection.classList.remove("d-none");
            } else {
                iceSection.classList.add("d-none");
            }

            // Toppings options
            const toppingsSection = document.getElementById("toppingsSection");
            const toppingsList = document.getElementById("toppingsOptionsList");
            if (product.toppings && product.toppings.length > 0) {
                toppingsSection.classList.remove("d-none");
                toppingsList.innerHTML = "";
                product.toppings.forEach(t => {
                    toppingsList.innerHTML += `
                        <label class="selectable-option">
                            <input type="checkbox" name="toppingOption" value="${t.id}" onchange="updateLivePrice()" />
                            <span class="option-card" style="flex-direction:row; justify-content:space-between; padding:10px 14px;">
                                <span class="option-label">${t.name}</span>
                                <span class="option-price">+${formatVND(t.price)}</span>
                            </span>
                        </label>
                    `;
                });
            } else {
                toppingsSection.classList.add("d-none");
                toppingsList.innerHTML = "";
            }

            // Points redemption option (Trà Sữa Truyền Thống id = 1, cost 50 points)
            const pointRow = document.getElementById("pointRedeemRow");
            const chkRedeem = document.getElementById("pointRedeemCheckbox");
            chkRedeem.checked = false;

            if (product.id === 1 && activeCustomer) {
                pointRow.classList.remove("d-none");
                if (activeCustomer.currentPoints >= 50) {
                    chkRedeem.disabled = false;
                } else {
                    chkRedeem.disabled = true;
                }
            } else {
                pointRow.classList.add("d-none");
            }

            updateLivePrice();
            openModal("customizationModal");
        }

        function changeModalQty(change) {
            modalQty += change;
            if (modalQty < 1) modalQty = 1;
            document.getElementById("modalQtyDisplay").innerText = modalQty;

            // Point redemption check
            const chkRedeem = document.getElementById("pointRedeemCheckbox");
            if (editingProduct.id === 1 && activeCustomer) {
                const cost = 50 * modalQty;
                if (activeCustomer.currentPoints >= cost) {
                    chkRedeem.disabled = false;
                } else {
                    chkRedeem.disabled = true;
                    chkRedeem.checked = false;
                }
            }

            updateLivePrice();
        }

        function togglePointRedemption() {
            updateLivePrice();
        }

        function updateLivePrice() {
            if (!editingProduct) return;

            let unitPrice = editingProduct.basePrice;

            // Selected size modifier
            if (editingProduct.hasSizeOption) {
                const selectedSizeInput = document.querySelector('input[name="sizeOption"]:checked');
                if (selectedSizeInput) {
                    const sizeId = parseInt(selectedSizeInput.value);
                    const sz = editingProduct.sizes.find(s => s.id === sizeId);
                    if (sz) {
                        unitPrice += sz.priceModifier;
                    }
                }
            }

            // If points redeem checked, item price becomes 0
            const chkRedeem = document.getElementById("pointRedeemCheckbox");
            const isRedeemed = chkRedeem && chkRedeem.checked;
            if (isRedeemed) {
                unitPrice = 0;
            }

            // Checked toppings
            let toppingsPrice = 0;
            const checkedToppings = document.querySelectorAll('input[name="toppingOption"]:checked');
            checkedToppings.forEach(chk => {
                const topId = parseInt(chk.value);
                const t = editingProduct.toppings.find(top => top.id === topId);
                if (t) {
                    toppingsPrice += t.price;
                }
            });

            const itemTotal = (unitPrice + toppingsPrice) * modalQty;
            
            document.getElementById("liveUnitPrice").innerText = `Đơn giá: ${formatVND(unitPrice + toppingsPrice)}`;
            document.getElementById("btnSaveCustomization").innerText = `THÊM VÀO GIỎ - ${formatVND(itemTotal)}`;
        }

        function submitCustomization() {
            if (!editingProduct) return;

            let sizeObj = { sizeLabel: "Regular", priceModifier: 0 };
            if (editingProduct.hasSizeOption) {
                const selectedSizeInput = document.querySelector('input[name="sizeOption"]:checked');
                if (selectedSizeInput) {
                    const sizeId = parseInt(selectedSizeInput.value);
                    sizeObj = editingProduct.sizes.find(s => s.id === sizeId);
                }
            }

            const sugar = editingProduct.hasSugarOption ? document.querySelector('input[name="sugarLevel"]:checked').value : "NA";
            const ice = editingProduct.hasIceOption ? document.querySelector('input[name="iceLevel"]:checked').value : "NA";

            const selectedToppings = [];
            const checkedToppings = document.querySelectorAll('input[name="toppingOption"]:checked');
            checkedToppings.forEach(chk => {
                const topId = parseInt(chk.value);
                const t = editingProduct.toppings.find(top => top.id === topId);
                if (t) {
                    selectedToppings.push(t);
                }
            });

            const notes = document.getElementById("modalNotes").value;
            const chkRedeem = document.getElementById("pointRedeemCheckbox");
            const isPointRedemption = chkRedeem && chkRedeem.checked;

            addToCart({
                product: editingProduct,
                quantity: modalQty,
                size: sizeObj,
                sugar: sugar,
                ice: ice,
                toppings: selectedToppings,
                notes: notes,
                isPointRedemption: isPointRedemption
            });

            closeModal("customizationModal");
        }

        // Cart Actions
        function addToCart(cartItem) {
            // Check if shift is open
            if (!activeShift) {
                showToast("Ca làm việc chưa được mở. Vui lòng mở ca trước khi bán hàng.", "error");
                return;
            }

            // Find duplicate with exactly same customizations
            const duplicateIndex = cart.findIndex(item => {
                if (item.product.id !== cartItem.product.id) return false;
                if (item.size.sizeLabel !== cartItem.size.sizeLabel) return false;
                if (item.sugar !== cartItem.sugar) return false;
                if (item.ice !== cartItem.ice) return false;
                if (item.notes !== cartItem.notes) return false;
                if (item.isPointRedemption !== cartItem.isPointRedemption) return false;
                if (item.toppings.length !== cartItem.toppings.length) return false;
                
                // Compare topping IDs
                const tIds1 = item.toppings.map(t => t.id).sort();
                const tIds2 = cartItem.toppings.map(t => t.id).sort();
                return tIds1.every((id, i) => id === tIds2[i]);
            });

            if (duplicateIndex > -1) {
                cart[duplicateIndex].quantity += cartItem.quantity;
            } else {
                cart.push(cartItem);
            }

            renderCart();
            showToast(`Đã thêm ${cartItem.product.name} vào giỏ hàng`, "success");
        }

        function updateCartQty(index, change) {
            cart[index].quantity += change;
            if (cart[index].quantity < 1) {
                cart.splice(index, 1);
            } else {
                // If points redemption, verify points cost is still allowed
                if (cart[index].isPointRedemption && activeCustomer) {
                    const totalCost = 50 * cart[index].quantity;
                    if (activeCustomer.currentPoints < totalCost) {
                        showToast("Không đủ điểm để nâng số lượng.", "warning");
                        cart[index].quantity -= change;
                    }
                }
            }
            renderCart();
        }

        function removeCartItem(index) {
            cart.splice(index, 1);
            renderCart();
        }

        function clearCart() {
            cart = [];
            activeVoucher = null;
            manualDiscount = { percent: 0, approverCode: null, approverNote: null };
            document.getElementById("voucherInput").value = "";
            renderCart();
        }

        // Render Cart Details
        function renderCart() {
            const list = document.getElementById("cartItemsList");
            const emptyState = document.getElementById("cartEmptyState");

            if (cart.length === 0) {
                list.innerHTML = "";
                list.appendChild(emptyState);
                calculateTotals();
                return;
            }

            // Remove empty state
            list.innerHTML = "";

            cart.forEach((item, idx) => {
                const toppingsStr = item.toppings.map(t => t.name).join(", ");
                const customSummary = `
                    Size ${item.size.sizeLabel}
                    ${item.sugar !== "NA" ? `• Đường: ${item.sugar}%` : ''}
                    ${item.ice !== "NA" ? `• Đá: ${item.ice}%` : ''}
                    ${toppingsStr ? `• Topping: ${toppingsStr}` : ''}
                    ${item.notes ? `• Ghi chú: "${item.notes}"` : ''}
                `.trim().replace(/\s+/g, ' ');

                let unitPrice = item.isPointRedemption ? 0 : item.product.basePrice + item.size.priceModifier;
                let toppingsPrice = item.toppings.reduce((sum, t) => sum + t.price, 0);
                let itemTotal = (unitPrice + toppingsPrice) * item.quantity;

                list.innerHTML += `
                    <div class="cart-item">
                        <div class="cart-item-detail">
                            <h5 class="cart-item-name">${item.product.name}</h5>
                            <p class="cart-item-meta">${customSummary}</p>
                            ${item.isPointRedemption ? `<div class="cart-item-point-redeem">🎁 Đổi 50 điểm</div>` : ''}
                            <div class="cart-item-price-row">
                                <span class="cart-item-price">${formatVND(itemTotal)}</span>
                                <div class="qty-stepper">
                                    <button class="stepper-btn" onclick="updateCartQty(${idx}, -1)">-</button>
                                    <span class="stepper-val">${item.quantity}</span>
                                    <button class="stepper-btn" onclick="updateCartQty(${idx}, 1)">+</button>
                                </div>
                            </div>
                        </div>
                        <button class="btn-remove-item" onclick="removeCartItem(${idx})">
                            <span class="material-symbols-outlined">delete</span>
                        </button>
                    </div>
                `;
            });

            calculateTotals();
        }

        // Totals Calculations
        function calculateTotals() {
            let subtotal = 0;
            
            cart.forEach(item => {
                let unitPrice = item.isPointRedemption ? 0 : item.product.basePrice + item.size.priceModifier;
                let toppingsPrice = item.toppings.reduce((sum, t) => sum + t.price, 0);
                subtotal += (unitPrice + toppingsPrice) * item.quantity;
            });

            // Loyalty Discount
            let loyaltyDiscount = 0;
            if (activeCustomer) {
                let discountPercent = 0;
                if (activeCustomer.loyaltyTier === "Silver") discountPercent = 10;
                if (activeCustomer.loyaltyTier === "Gold") discountPercent = 15;
                
                loyaltyDiscount = subtotal * (discountPercent / 100);
            }

            // Voucher Discount
            let voucherDiscount = 0;
            if (activeVoucher) {
                if (subtotal >= activeVoucher.minOrderValue) {
                    if (activeVoucher.discountType === "Percent") {
                        voucherDiscount = subtotal * (activeVoucher.discountValue / 100);
                    } else {
                        voucherDiscount = activeVoucher.discountValue;
                    }
                } else {
                    activeVoucher = null;
                    document.getElementById("voucherInput").value = "";
                    showToast("Giá trị đơn hàng không đủ điều kiện dùng voucher này. Đã hủy áp dụng.", "warning");
                }
            }

            // Manual Discount
            let manualDiscountAmount = subtotal * (manualDiscount.percent / 100);

            // Grand Total
            let totalDiscounts = loyaltyDiscount + voucherDiscount + manualDiscountAmount;
            if (totalDiscounts > subtotal) {
                totalDiscounts = subtotal;
            }
            let grandTotal = subtotal - totalDiscounts;

            document.getElementById("billSubtotal").innerText = formatVND(subtotal);
            document.getElementById("billLoyaltyDiscount").innerText = `-${formatVND(loyaltyDiscount)}`;
            document.getElementById("billVoucherDiscount").innerText = `-${formatVND(voucherDiscount)}`;
            document.getElementById("billManualDiscount").innerText = `-${formatVND(manualDiscountAmount)}`;
            document.getElementById("billGrandTotal").innerText = formatVND(grandTotal);

            // Action Checkout update price
            document.querySelector(".btn-checkout").innerText = `THANH TOÁN (${formatVND(grandTotal)})`;
        }

        // Customer Lookup
        async function lookupCustomer() {
            const phone = document.getElementById("customerPhoneInput").value;
            if (!phone || phone.length < 9) {
                showToast("Số điện thoại không hợp lệ.", "error");
                return;
            }

            const token = localStorage.getItem("token");

            try {
                const res = await fetch(`${API_URL}/customers/lookup?phone=${phone}`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const result = await res.json();

                if (res.ok && result.success) {
                    activeCustomer = result.data;
                    renderCustomerInfo();
                    calculateTotals();
                    showToast(`Đã nhận diện thành viên: ${activeCustomer.fullName}`, "success");
                } else {
                    showToast("Không tìm thấy số điện thoại khách hàng.", "error");
                    clearCustomer();
                }
            } catch (err) {
                console.error(err);
                showToast("Lỗi khi tìm kiếm khách hàng.", "error");
            }
        }

        function renderCustomerInfo() {
            const box = document.getElementById("customerDetailsBox");
            if (activeCustomer) {
                document.getElementById("custName").innerText = activeCustomer.fullName;
                document.getElementById("custPoints").innerText = `Điểm tích lũy: ${activeCustomer.currentPoints} pt`;
                
                const tierEl = document.getElementById("custTier");
                tierEl.innerText = activeCustomer.loyaltyTier;
                tierEl.className = `cust-tier ${activeCustomer.loyaltyTier.toLowerCase()}`;
                
                box.classList.remove("d-none");
            } else {
                box.classList.add("d-none");
            }
        }

        function clearCustomer() {
            activeCustomer = null;
            document.getElementById("customerPhoneInput").value = "";
            renderCustomerInfo();
            // Reset points redemption in cart if any
            cart.forEach(item => {
                item.isPointRedemption = false;
            });
            renderCart();
        }

        // Voucher Application
        async function applyVoucher() {
            const code = document.getElementById("voucherInput").value.trim().toUpperCase();
            if (!code) {
                showToast("Vui lòng nhập mã giảm giá.", "error");
                return;
            }

            // Create temporary draft order totals to validate voucher limits
            let subtotal = 0;
            cart.forEach(item => {
                let unitPrice = item.isPointRedemption ? 0 : item.product.basePrice + item.size.priceModifier;
                let toppingsPrice = item.toppings.reduce((sum, t) => sum + t.price, 0);
                subtotal += (unitPrice + toppingsPrice) * item.quantity;
            });

            if (subtotal === 0) {
                showToast("Vui lòng chọn sản phẩm vào giỏ trước.", "warning");
                return;
            }

            const token = localStorage.getItem("token");

            try {
                // Since there is no explicit Voucher check endpoint, we lookup the seeder codes locally first,
                // or we call orders create draft with voucher. But wait, we can mock it here or call a dummy endpoint.
                // To keep it 100% robust and matching API, let's call API. Oh wait, SUMMER10 and CAFE5K are seeded.
                // Let's simulate voucher lookup to give immediate feedback.
                if (code === "SUMMER10") {
                    if (subtotal < 50000) {
                        showToast("Tổng đơn chưa đạt giá trị tối thiểu 50,000đ để áp dụng SUMMER10.", "error");
                        return;
                    }
                    activeVoucher = { code: "SUMMER10", discountType: "Percent", discountValue: 10, minOrderValue: 50000 };
                    calculateTotals();
                    showToast("Áp dụng thành công Voucher giảm 10%", "success");
                } else if (code === "CAFE5K") {
                    if (subtotal < 30000) {
                        showToast("Tổng đơn chưa đạt giá trị tối thiểu 30,000đ để áp dụng CAFE5K.", "error");
                        return;
                    }
                    activeVoucher = { code: "CAFE5K", discountType: "Fixed", discountValue: 5000, minOrderValue: 30000 };
                    calculateTotals();
                    showToast("Áp dụng thành công Voucher giảm 5,000đ", "success");
                } else {
                    showToast("Mã voucher không tồn tại hoặc đã hết hạn.", "error");
                }
            } catch (err) {
                showToast("Không kiểm tra được mã giảm giá.", "error");
            }
        }

        // Supervisor discount (PIN pad)
        function openSupervisorModal() {
            if (cart.length === 0) {
                showToast("Giỏ hàng trống.", "warning");
                return;
            }
            supervisorPin = "";
            document.getElementById("pinDisplay").innerText = "••••••";
            document.getElementById("approverNoteInput").value = "";
            openModal("supervisorModal");
        }

        function pressPin(digit) {
            if (supervisorPin.length < 6) {
                supervisorPin += digit;
                updatePinDisplay();
            }
        }

        function clearPin() {
            supervisorPin = "";
            updatePinDisplay();
        }

        function updatePinDisplay() {
            const display = document.getElementById("pinDisplay");
            display.innerText = "•".repeat(supervisorPin.length) + "•".repeat(6 - supervisorPin.length);
        }

        async function submitSupervisorAuth() {
            if (supervisorPin.length < 6) {
                showToast("Mã PIN phải có 6 chữ số.", "error");
                return;
            }

            const token = localStorage.getItem("token");
            const discountPercent = parseFloat(document.querySelector('input[name="discountPercentOpt"]:checked').value);
            const notes = document.getElementById("approverNoteInput").value;

            try {
                // Verify PIN
                const res = await fetch(`${API_URL}/auth/staff/verify-code`, {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({ 
                        posCode: supervisorPin,
                        requiredRole: "ShiftLeader"
                    })
                });

                const result = await res.json();

                if (res.ok && result.success) {
                    if (result.data.isValid) {
                        manualDiscount = {
                            percent: discountPercent,
                            approverCode: supervisorPin,
                            approverNote: notes || `Phê duyệt bởi ${result.data.staffName} (${result.data.role})`
                        };
                        
                        document.getElementById("manualDiscountDisplay").innerText = `${discountPercent}%`;
                        calculateTotals();
                        showToast(`Giảm giá ${discountPercent}% đã được áp dụng.`, "success");
                        closeModal("supervisorModal");
                    } else {
                        showToast(result.data.message || "Mã xác thực không hợp lệ.", "error");
                        clearPin();
                    }
                } else {
                    showToast("Lỗi khi kết nối đến API xác thực.", "error");
                    clearPin();
                }
            } catch (err) {
                console.error(err);
                showToast("Lỗi hệ thống.", "error");
                clearPin();
            }
        }

        // Checkout Operations
        async function handleCheckout() {
            if (cart.length === 0) {
                showToast("Vui lòng thêm sản phẩm vào giỏ.", "warning");
                return;
            }
            if (!activeShift) {
                showToast("Ca làm việc chưa được mở. Vui lòng liên hệ Shift Leader.", "error");
                return;
            }

            const token = localStorage.getItem("token");

            // Build item request array
            const itemReqs = cart.map(item => {
                return {
                    productId: item.product.id,
                    quantity: item.quantity,
                    sizeLabel: item.size.sizeLabel,
                    sugarLevel: item.sugar,
                    iceLevel: item.ice,
                    toppingIds: item.toppings.map(t => t.id),
                    notes: item.notes,
                    isPointRedemption: item.isPointRedemption
                };
            });

            // Create Order Request Body
            const orderReq = {
                type: servingType,
                customerPhone: activeCustomer ? activeCustomer.phone : null,
                customerName: activeCustomer ? activeCustomer.fullName : null,
                scheduledPickupTime: null,
                items: itemReqs,
                voucherCode: activeVoucher ? activeVoucher.code : null,
                applyLoyaltyDiscount: !!activeCustomer,
                manualDiscountPercent: manualDiscount.percent,
                manualDiscountApproverCode: manualDiscount.approverCode
            };

            try {
                // Step 1: POST to create Draft order
                const res = await fetch(`${API_URL}/orders`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify(orderReq)
                });

                const result = await res.json();

                if (res.ok && result.success) {
                    activeDraftOrder = result.data;
                    openCheckoutModal();
                } else {
                    showToast(result.message || "Không thể tạo đơn hàng nháp.", "error");
                }
            } catch (err) {
                console.error(err);
                showToast("Lỗi máy chủ khi tạo đơn.", "error");
            }
        }

        function openCheckoutModal() {
            if (!activeDraftOrder) return;

            document.getElementById("checkTotal").innerText = formatVND(activeDraftOrder.totalAmount);
            document.getElementById("cashReceivedInput").value = "";
            document.getElementById("mixedCashInput").value = "";
            document.getElementById("mixedTransferInput").value = "";
            
            // Set payment radio to Cash
            document.querySelector('input[name="payMethod"][value="Cash"]').checked = true;
            togglePayMethod("Cash");

            openModal("checkoutModal");
        }

        function togglePayMethod(method) {
            const cashBox = document.getElementById("cashDetailsBox");
            const transferBox = document.getElementById("transferDetailsBox");
            const mixedBox = document.getElementById("mixedDetailsBox");

            const cashReceivedRow = document.getElementById("checkCashReceivedRow");
            const changeRow = document.getElementById("checkChangeRow");

            if (method === "Cash") {
                cashBox.classList.remove("d-none");
                transferBox.classList.add("d-none");
                mixedBox.classList.add("d-none");
                cashReceivedRow.classList.remove("d-none");
                changeRow.classList.remove("d-none");
                onCashReceivedInput();
            } else if (method === "Transfer") {
                cashBox.classList.add("d-none");
                transferBox.classList.remove("d-none");
                mixedBox.classList.add("d-none");
                cashReceivedRow.classList.add("d-none");
                changeRow.classList.add("d-none");
                
                // Render VietQR image dynamic
                const amount = activeDraftOrder.totalAmount;
                const code = activeDraftOrder.orderCode;
                document.getElementById("qrAmountDisplay").innerText = formatVND(amount);
                document.getElementById("qrContentDisplay").innerText = code;
                
                // Use quick qr server with VietQR layout data link
                const qrData = encodeURIComponent(`https://vietqr.me/api/qr/MBBank/2302888888/${amount}/${code}`);
                document.getElementById("vietqrImage").src = `https://api.qrserver.com/v1/create-qr-code/?size=160x160&data=${qrData}`;
            } else { // Mixed
                cashBox.classList.add("d-none");
                transferBox.classList.remove("d-none");
                mixedBox.classList.remove("d-none");
                cashReceivedRow.classList.add("d-none");
                changeRow.classList.add("d-none");

                // Initialize mixed fields
                document.getElementById("mixedCashInput").value = "";
                document.getElementById("mixedTransferInput").value = activeDraftOrder.totalAmount;

                // QR updates
                document.getElementById("qrAmountDisplay").innerText = formatVND(activeDraftOrder.totalAmount);
                document.getElementById("qrContentDisplay").innerText = activeDraftOrder.orderCode;
                const qrData = encodeURIComponent(`https://vietqr.me/api/qr/MBBank/2302888888/${activeDraftOrder.totalAmount}/${activeDraftOrder.orderCode}`);
                document.getElementById("vietqrImage").src = `https://api.qrserver.com/v1/create-qr-code/?size=160x160&data=${qrData}`;
            }
        }

        // Cash calculations
        function onCashReceivedInput() {
            const input = document.getElementById("cashReceivedInput");
            const cash = parseFloat(input.value) || 0;
            const total = activeDraftOrder.totalAmount;
            
            document.getElementById("checkReceived").innerText = formatVND(cash);

            const change = cash - total;
            document.getElementById("checkChange").innerText = change >= 0 ? formatVND(change) : "Chưa đủ";
        }

        function addHelperCash(amount) {
            const input = document.getElementById("cashReceivedInput");
            const total = activeDraftOrder.totalAmount;

            if (amount === 0) {
                input.value = total;
            } else {
                const current = parseFloat(input.value) || 0;
                input.value = current + amount;
            }
            onCashReceivedInput();
        }

        // Mixed calculations
        function onMixedAmountsInput() {
            const total = activeDraftOrder.totalAmount;
            const cashInput = document.getElementById("mixedCashInput");
            const transferInput = document.getElementById("mixedTransferInput");

            const cash = parseFloat(cashInput.value) || 0;
            const transfer = Math.max(0, total - cash);

            transferInput.value = transfer;
            document.getElementById("qrAmountDisplay").innerText = formatVND(transfer);

            // Re-generate QR for the transfer portion
            const code = activeDraftOrder.orderCode;
            const qrData = encodeURIComponent(`https://vietqr.me/api/qr/MBBank/2302888888/${transfer}/${code}`);
            document.getElementById("vietqrImage").src = `https://api.qrserver.com/v1/create-qr-code/?size=160x160&data=${qrData}`;
        }

        // Complete Checkout payment
        async function submitPayment() {
            if (!activeDraftOrder) return;

            const token = localStorage.getItem("token");
            const method = document.querySelector('input[name="payMethod"]:checked').value;
            
            let amountReceived = activeDraftOrder.totalAmount;
            let refCode = null;

            if (method === "Cash") {
                const cash = parseFloat(document.getElementById("cashReceivedInput").value) || 0;
                if (cash < activeDraftOrder.totalAmount) {
                    showToast("Khách đưa tiền mặt chưa đủ giá trị đơn hàng.", "error");
                    return;
                }
                amountReceived = cash;
            } else if (method === "Mixed") {
                const cash = parseFloat(document.getElementById("mixedCashInput").value) || 0;
                const transfer = parseFloat(document.getElementById("mixedTransferInput").value) || 0;
                if (cash + transfer < activeDraftOrder.totalAmount) {
                    showToast("Tổng tiền mặt và chuyển khoản chưa đủ.", "error");
                    return;
                }
                amountReceived = cash; // In Mixed, backend registers cash as received cash.
                refCode = "Mixed-Transfer Portion: " + transfer;
            } else { // Transfer
                refCode = "QR-" + activeDraftOrder.orderCode;
            }

            try {
                // POST to Process Payment
                const res = await fetch(`${API_URL}/orders/${activeDraftOrder.id}/payment`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({
                        paymentMethod: method,
                        amountReceived: amountReceived,
                        referenceCode: refCode
                    })
                });

                const result = await res.json();

                if (res.ok && result.success) {
                    showToast("Thanh toán thành công!", "success");
                    
                    // Render Receipt info
                    alert(`✓ THÀNH CÔNG!\n\nMã đơn: ${activeDraftOrder.orderCode}\nTổng tiền: ${formatVND(activeDraftOrder.totalAmount)}\nKhách đưa: ${formatVND(amountReceived)}\nThối lại: ${formatVND(Math.max(0, amountReceived - activeDraftOrder.totalAmount))}`);

                    // Clean and reset
                    closeModal("checkoutModal");
                    clearCart();
                    clearCustomer();
                    await checkShiftStatus(); // Refresh shift stats
                } else {
                    // Handle optimistic concurrency Conflict 409
                    if (res.status === 409) {
                        showToast("⚠️ Thất bại: Đơn hàng đã được thay đổi bởi luồng khác. Vui lòng kiểm tra và thanh toán lại.", "error");
                    } else {
                        showToast(result.message || "Lỗi thanh toán.", "error");
                    }
                }
            } catch (err) {
                console.error(err);
                showToast("Lỗi kết nối máy chủ thanh toán.", "error");
            }
        }

        // Toggle Serving Type
        function setServingType(type) {
            servingType = type;
            document.getElementById("btnDineIn").classList.toggle("active", type === "DineIn");
            document.getElementById("btnTakeAway").classList.toggle("active", type === "TakeAway");
        }

        // Translate user roles
        function translateRole(role) {
            switch(role) {
                case 'Owner': return 'Chủ cửa hàng';
                case 'ShiftLeader': return 'Trưởng ca';
                case 'Cashier': return 'Thu ngân';
                case 'Barista': return 'Pha chế';
                case 'PastryStaff': return 'Làm bánh';
                default: return role;
            }
        }

        // Format Currency
        function formatVND(amount) {
            return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(amount);
        }

        // Modal triggers
        function openModal(id) {
            document.getElementById(id).classList.add("open");
        }

        function closeModal(id) {
            document.getElementById(id).classList.remove("open");
        }

        // Toast Messages
        function showToast(msg, type = "success") {
            const container = document.getElementById("toastContainer");
            const toast = document.createElement("div");
            toast.className = `toast-message ${type}`;
            toast.innerHTML = `
                <span class="material-symbols-outlined">${type === 'success' ? 'check_circle' : type === 'error' ? 'error' : 'warning'}</span>
                <span>${msg}</span>
            `;
            container.appendChild(toast);

            // Trigger animation
            setTimeout(() => toast.classList.add("show"), 100);

            // Destroy
            setTimeout(() => {
                toast.classList.remove("show");
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // Clear JWT and Logout
        function logout() {
            localStorage.removeItem("token");
            localStorage.removeItem("staff");
            localStorage.removeItem("loginMode");
            window.location.href = "/POS/Login";
        }
    </script>
</body>
</html>

