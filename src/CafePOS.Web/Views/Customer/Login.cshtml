@{
    ViewData["Title"] = "Cổng Khách Hàng - Đăng nhập";
    Layout = null; // Independent customized design
}

<!DOCTYPE html>
<html lang="vi" class="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CafePOS</title>
    <!-- Google Identity Services Library -->
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <!-- Nunito Sans Font & Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@400;600;700;800&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <!-- Tailwind CSS CDN with forms/container plugins -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              "colors": {
                      "surface-dim": "#dcdad6",
                      "primary-container": "#4c7031",
                      "surface-bright": "#fcf9f5",
                      "on-secondary": "#ffffff",
                      "on-secondary-container": "#795d4e",
                      "tertiary-fixed-dim": "#e5c099",
                      "on-tertiary": "#ffffff",
                      "tertiary": "#64492b",
                      "on-tertiary-container": "#ffe0c2",
                      "tertiary-fixed": "#ffddbb",
                      "secondary-container": "#fed8c5",
                      "on-error-container": "#93000a",
                      "on-primary-fixed": "#0b2000",
                      "error-container": "#ffdad6",
                      "on-error": "#ffffff",
                      "secondary-fixed-dim": "#e3bfad",
                      "on-surface": "#1c1c1a",
                      "surface-tint": "#44682a",
                      "on-primary-container": "#c7f2a4",
                      "inverse-on-surface": "#f3f0ec",
                      "surface-container-highest": "#e5e2de",
                      "on-background": "#1c1c1a",
                      "background": "#fcf9f5",
                      "on-primary": "#ffffff",
                      "surface-container": "#f0ede9",
                      "on-primary-fixed-variant": "#2d4f14",
                      "tertiary-container": "#7e6141",
                      "surface-container-high": "#eae8e4",
                      "on-secondary-fixed": "#2a170c",
                      "primary-fixed-dim": "#a9d388",
                      "surface-variant": "#e5e2de",
                      "surface-container-low": "#f6f3ef",
                      "surface": "#fcf9f5",
                      "secondary-fixed": "#ffdbca",
                      "on-secondary-fixed-variant": "#5a4134",
                      "outline-variant": "#c3c9b9",
                      "secondary": "#74584a",
                      "on-surface-variant": "#43493d",
                      "error": "#ba1a1a",
                      "on-tertiary-fixed": "#2b1701",
                      "on-tertiary-fixed-variant": "#5c4224",
                      "surface-container-lowest": "#ffffff",
                      "primary-fixed": "#c5efa2",
                      "inverse-primary": "#a9d388",
                      "primary": "#35571b",
                      "outline": "#73796c",
                      "inverse-surface": "#31302e",
                      // Custom semantic colors
                      "espresso-dark": "#2c1b18",
                      "milk-bg": "#fdfaf6",
                      "cream-bg": "#f4eae1",
                      "beige-accent": "#ddb892",
                      "matcha-primary": "#4c7031"
              },
              "borderRadius": {
                      "DEFAULT": "0.25rem",
                      "lg": "0.5rem",
                      "xl": "0.75rem",
                      "full": "9999px",
                      "2xl": "1.5rem"
              },
              "spacing": {
                      "base": "4px",
                      "xs": "4px",
                      "sm": "8px",
                      "gutter": "16px",
                      "margin-mobile": "16px",
                      "2xl": "64px",
                      "lg": "24px",
                      "margin-desktop": "32px",
                      "xl": "40px",
                      "md": "16px"
              },
              "fontFamily": {
                      "headline-lg-mobile": ["Nunito Sans"],
                      "body-lg": ["Nunito Sans"],
                      "label-sm": ["Nunito Sans"],
                      "title-lg": ["Nunito Sans"],
                      "label-md": ["Nunito Sans"],
                      "headline-md": ["Nunito Sans"],
                      "display-lg": ["Nunito Sans"],
                      "headline-lg": ["Nunito Sans"],
                      "body-md": ["Nunito Sans"]
              },
              "fontSize": {
                      "headline-lg-mobile": ["24px", { "lineHeight": "32px", "fontWeight": "700" }],
                      "body-lg": ["18px", { "lineHeight": "28px", "fontWeight": "400" }],
                      "label-sm": ["12px", { "lineHeight": "16px", "fontWeight": "700" }],
                      "title-lg": ["20px", { "lineHeight": "28px", "fontWeight": "600" }],
                      "label-md": ["14px", { "lineHeight": "20px", "letterSpacing": "0.01em", "fontWeight": "600" }],
                      "headline-md": ["24px", { "lineHeight": "32px", "fontWeight": "700" }],
                      "display-lg": ["48px", { "lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "800" }],
                      "headline-lg": ["32px", { "lineHeight": "40px", "fontWeight": "700" }],
                      "body-md": ["16px", { "lineHeight": "24px", "fontWeight": "400" }]
              },
              "boxShadow": {
                  "coffee": "0px 4px 12px rgba(44, 27, 24, 0.08)"
              }
            },
          }
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .material-symbols-outlined[data-weight="fill"] {
            font-variation-settings: 'FILL' 1;
        }
        html, body {
            min-height: 100vh;
            margin: 0;
            padding: 0;
            font-family: 'Nunito Sans', sans-serif;
            background-color: #fdfaf6;
        }
        /* Fluid Panel Transitions */
        .panel-transition {
            transition: opacity 0.3s ease-in-out, transform 0.3s ease-in-out;
        }
        .panel-hidden {
            display: none !important;
            opacity: 0;
            transform: translateY(12px);
        }
        .panel-visible {
            display: flex !important;
            opacity: 1;
            transform: translateY(0);
        }
    </style>
</head>
<body class="min-h-screen flex flex-col justify-between items-center px-4 py-6 antialiased relative overflow-y-auto selection:bg-primary-container selection:text-on-primary-container">
    
    <!-- Ambient Background Light Decorations -->
    <div class="fixed top-0 left-0 w-full h-full overflow-hidden pointer-events-none z-0">
        <div class="absolute top-[-10%] left-[-10%] w-[50vw] h-[50vw] rounded-full bg-secondary-container/15 blur-[100px]"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[40vw] h-[40vw] rounded-full bg-primary-fixed/15 blur-[100px]"></div>
    </div>

    <!-- Main Container Wrapper -->
    <div class="flex-grow flex items-center justify-center w-full my-8 relative z-10">
        <main class="w-full max-w-[450px] px-2">
            <!-- Wrapper Card -->
            <div class="bg-surface-container-lowest rounded-2xl shadow-coffee p-6 md:p-10 border border-outline-variant/30 flex flex-col gap-6 relative overflow-hidden">
            
            <!-- Global Overlay for Loading and Statuses -->
            <div id="successOverlay" class="absolute inset-0 bg-[#fdfaf6]/95 z-50 flex flex-col items-center justify-center gap-4 opacity-0 pointer-events-none transition-all duration-300 rounded-2xl">
                <div id="successSpinner" class="w-12 h-12 border-4 border-primary/20 border-t-primary rounded-full animate-spin"></div>
                <div id="successCheck" class="hidden w-16 h-16 rounded-full bg-primary/10 border-2 border-primary flex items-center justify-center text-primary">
                    <span class="material-symbols-outlined text-headline-lg font-bold">check</span>
                </div>
                <div id="successTitle" class="font-headline-md text-headline-md text-espresso-dark">Đang xử lý...</div>
            </div>

            <!-- Custom Alerts (Errors and Successes) -->
            <div id="errorAlert" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm animate-bounce" role="alert"></div>
            <div id="successAlert" class="hidden bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl text-sm" role="alert"></div>

            <!-- PANEL 1: CUSTOMER LOGIN -->
            <div id="panelLogin" class="panel-transition panel-visible flex flex-col gap-6">
                <!-- Header -->
                <header class="flex flex-col items-center text-center gap-2">
                    <h1 class="font-display-lg text-display-lg text-primary tracking-tight">CafePOS</h1>
                    <p class="font-body-md text-body-md text-on-surface-variant max-w-[280px]">Chào mừng trở lại! Đăng nhập để tiếp tục trải nghiệm hương vị tuyệt vời.</p>
                </header>

                <!-- Login Form -->
                <form onsubmit="submitLogin(event)" class="flex flex-col gap-4">
                    <!-- Phone Input -->
                    <div class="flex flex-col gap-1">
                        <label class="font-label-md text-label-md text-espresso-dark ml-1" for="loginPhone">Số điện thoại</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-outline-variant">
                                <span class="material-symbols-outlined text-[20px]">person</span>
                            </span>
                            <input class="w-full bg-cream-bg border border-transparent focus:border-beige-accent focus:ring-0 rounded-lg pl-11 pr-4 py-3 font-body-md text-body-md text-espresso-dark placeholder-outline-variant/60 transition-colors outline-none h-[48px]" id="loginPhone" placeholder="Nhập số điện thoại (09xxxxxxxx)" required type="tel"/>
                        </div>
                    </div>

                    <!-- Password Input -->
                    <div class="flex flex-col gap-1">
                        <label class="font-label-md text-label-md text-espresso-dark ml-1" for="loginPassword">Mật khẩu</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-outline-variant">
                                <span class="material-symbols-outlined text-[20px]">lock</span>
                            </span>
                            <input class="w-full bg-cream-bg border border-transparent focus:border-beige-accent focus:ring-0 rounded-lg pl-11 pr-12 py-3 font-body-md text-body-md text-espresso-dark placeholder-outline-variant/60 transition-colors outline-none h-[48px]" id="loginPassword" placeholder="Nhập mật khẩu" required type="password"/>
                            <button aria-label="Hiện mật khẩu" class="absolute inset-y-0 right-0 flex items-center pr-4 text-outline-variant hover:text-espresso-dark transition-colors" type="button" onclick="togglePasswordVisibility('loginPassword', this)">
                                <span class="material-symbols-outlined text-[20px]">visibility_off</span>
                            </button>
                        </div>
                    </div>

                    <!-- Options: Remember Me & Forgot Password -->
                    <div class="flex justify-between items-center mt-1">
                        <label class="flex items-center gap-2 cursor-pointer group">
                            <input class="w-4 h-4 rounded border-outline-variant text-matcha-primary focus:ring-matcha-primary focus:ring-offset-0 bg-cream-bg transition-colors cursor-pointer" type="checkbox"/>
                            <span class="font-body-md text-body-md text-on-surface-variant group-hover:text-espresso-dark transition-colors">Ghi nhớ đăng nhập</span>
                        </label>
                        <button type="button" class="font-label-md text-label-md text-matcha-primary hover:text-primary-fixed-variant transition-colors underline-offset-4 hover:underline outline-none" onclick="switchPanel('forgot')">Quên mật khẩu?</button>
                    </div>

                    <!-- Primary Login Button -->
                    <button class="w-full bg-matcha-primary hover:bg-primary-fixed-variant text-on-primary font-title-lg text-title-lg rounded-lg h-[48px] px-md flex items-center justify-center gap-2 transition-all active:scale-[0.98] shadow-sm mt-2" type="submit">
                        <span>Đăng nhập</span>
                        <span class="material-symbols-outlined">arrow_forward</span>
                    </button>
                </form>

                <!-- Divider -->
                <div class="relative flex items-center py-1">
                    <div class="flex-grow border-t border-outline-variant/30"></div>
                    <span class="flex-shrink-0 mx-4 font-label-sm text-label-sm text-outline uppercase tracking-wider">Hoặc</span>
                    <div class="flex-grow border-t border-outline-variant/30"></div>
                </div>

                <!-- Google Authentication (Real) -->
                <div class="flex flex-col gap-3">
                    <div class="w-full flex justify-center h-[48px] overflow-hidden rounded-lg">
                        <div id="g_id_onload"
                             data-client_id="557721054728-0g2fncq9khmlciuhkrjn5cccdpqpb7un.apps.googleusercontent.com"
                             data-context="signin"
                             data-ux_mode="popup"
                             data-callback="handleCredentialResponse"
                             data-auto_prompt="false">
                        </div>
                        <div class="g_id_signin"
                             data-type="standard"
                             data-shape="rectangular"
                             data-theme="outline"
                             data-text="signin_with"
                             data-size="large"
                             data-logo_alignment="left"
                             style="width: 100%;">
                        </div>
                    </div>
                </div>

                <!-- Footer Sign up prompt -->
                <div class="text-center mt-2">
                    <p class="font-body-md text-body-md text-on-surface-variant">
                        Chưa có tài khoản? 
                        <button type="button" class="font-label-md text-label-md text-matcha-primary hover:text-primary-fixed-variant transition-colors hover:underline underline-offset-4 ml-1 focus:outline-none" onclick="switchPanel('register')">Đăng ký ngay</button>
                    </p>
                </div>
            </div>

            <!-- PANEL 2: CUSTOMER REGISTER -->
            <div id="panelRegister" class="panel-transition panel-hidden flex flex-col gap-6">
                <!-- Icon and Header -->
                <header class="text-center flex flex-col items-center gap-2">
                    <div class="w-14 h-14 rounded-full bg-surface-container-low flex items-center justify-center text-primary border border-outline-variant/30 mb-1">
                        <span class="material-symbols-outlined text-headline-md">local_cafe</span>
                    </div>
                    <h1 class="font-headline-md text-headline-md text-on-surface">Tạo tài khoản mới</h1>
                    <p class="font-body-md text-body-md text-on-surface-variant">Tham gia cùng chúng tôi để trải nghiệm đặt đồ uống tuyệt vời</p>
                </header>

                <!-- Register Form -->
                <form onsubmit="submitRegister(event)" class="w-full flex flex-col gap-3">
                    <!-- Họ và tên -->
                    <div class="flex flex-col gap-1">
                        <label class="font-label-md text-label-md text-on-surface-variant ml-1" for="regName">Họ và tên</label>
                        <input class="w-full bg-surface-container-low border border-outline-variant/50 rounded-lg py-2.5 px-4 focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary text-on-surface font-body-md transition-all placeholder:text-on-surface-variant/40 h-[46px]" id="regName" placeholder="Nhập họ và tên" required type="text"/>
                    </div>

                    <!-- Số điện thoại -->
                    <div class="flex flex-col gap-1">
                        <label class="font-label-md text-label-md text-on-surface-variant ml-1" for="regPhone">Số điện thoại</label>
                        <input class="w-full bg-surface-container-low border border-outline-variant/50 rounded-lg py-2.5 px-4 focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary text-on-surface font-body-md transition-all placeholder:text-on-surface-variant/40 h-[46px]" id="regPhone" placeholder="Nhập số điện thoại" required type="tel"/>
                    </div>

                    <!-- Email -->
                    <div class="flex flex-col gap-1">
                        <label class="font-label-md text-label-md text-on-surface-variant ml-1" for="regEmail">Email</label>
                        <input class="w-full bg-surface-container-low border border-outline-variant/50 rounded-lg py-2.5 px-4 focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary text-on-surface font-body-md transition-all placeholder:text-on-surface-variant/40 h-[46px]" id="regEmail" placeholder="Nhập địa chỉ email" required type="email"/>
                    </div>

                    <!-- Mật khẩu -->
                    <div class="flex flex-col gap-1">
                        <label class="font-label-md text-label-md text-on-surface-variant ml-1" for="regPassword">Mật khẩu</label>
                        <div class="relative">
                            <input class="w-full bg-surface-container-low border border-outline-variant/50 rounded-lg py-2.5 pl-4 pr-12 focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary text-on-surface font-body-md transition-all placeholder:text-on-surface-variant/40 h-[46px]" id="regPassword" placeholder="Nhập mật khẩu" required type="password"/>
                            <button aria-label="Hiện mật khẩu" class="absolute right-4 top-1/2 -translate-y-1/2 text-sm font-semibold text-matcha-primary hover:text-primary transition-colors focus:outline-none" type="button" onclick="togglePasswordVisibility('regPassword', this)">Hiện</button>
                        </div>
                    </div>

                    <!-- Xác nhận mật khẩu -->
                    <div class="flex flex-col gap-1">
                        <label class="font-label-md text-label-md text-on-surface-variant ml-1" for="regConfirmPassword">Xác nhận mật khẩu</label>
                        <input class="w-full bg-surface-container-low border border-outline-variant/50 rounded-lg py-2.5 px-4 focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary text-on-surface font-body-md transition-all placeholder:text-on-surface-variant/40 h-[46px]" id="regConfirmPassword" placeholder="Nhập lại mật khẩu" required type="password"/>
                    </div>

                    <!-- Điều khoản -->
                    <div class="flex items-start gap-3 mt-2">
                        <div class="flex items-center h-6">
                            <input class="w-5 h-5 rounded border-outline-variant text-primary focus:ring-primary bg-surface-container-low cursor-pointer" id="terms" required type="checkbox"/>
                        </div>
                        <label class="font-body-md text-body-md text-on-surface-variant cursor-pointer" for="terms">
                            Tôi đồng ý với <a class="text-primary hover:underline font-label-md" href="#">Điều khoản sử dụng</a> và <a class="text-primary hover:underline font-label-md" href="#">Chính sách bảo mật</a>
                        </label>
                    </div>

                    <!-- Submit Button -->
                    <button class="w-full h-[52px] mt-4 bg-primary-container text-on-primary-container font-title-lg text-title-lg rounded-xl hover:bg-primary-fixed-dim transition-colors shadow-sm flex items-center justify-center gap-2" type="submit">
                        <span>Đăng ký</span>
                    </button>
                </form>

                <!-- Divider -->
                <div class="w-full flex items-center gap-4 my-2">
                    <div class="flex-1 h-px bg-outline-variant/30"></div>
                    <span class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Hoặc</span>
                    <div class="flex-1 h-px bg-outline-variant/30"></div>
                </div>

                <!-- Back to login link -->
                <p class="font-body-md text-body-md text-on-surface-variant text-center">
                    Đã có tài khoản? 
                    <button type="button" class="text-primary font-label-md text-label-md hover:underline hover:text-primary-fixed-dim transition-colors focus:outline-none" onclick="switchPanel('login')">Đăng nhập ngay</button>
                </p>
            </div>

            <!-- PANEL 3: CUSTOMER FORGOT PASSWORD -->
            <div id="panelForgotPassword" class="panel-transition panel-hidden flex flex-col gap-6">
                <!-- Header -->
                <header class="text-center flex flex-col items-center gap-2">
                    <div class="w-14 h-14 rounded-full bg-surface-container flex items-center justify-center text-primary mb-1 shadow-inner border border-outline-variant/30">
                        <span class="material-symbols-outlined text-[28px]" style="font-variation-settings: 'FILL' 1;">lock_reset</span>
                    </div>
                    <h1 class="font-headline-md text-headline-md text-on-surface">Khôi phục mật khẩu</h1>
                    <p class="font-body-md text-body-md text-on-surface-variant px-2">
                        Nhập số điện thoại hoặc email đã đăng ký để nhận hướng dẫn đặt lại mật khẩu
                    </p>
                </header>

                <!-- Forgot Password Form -->
                <form onsubmit="submitForgotPassword(event)" class="flex flex-col gap-4">
                    <div class="flex flex-col gap-1">
                        <label class="font-label-md text-label-md text-on-surface-variant ml-1" for="forgotIdentifier">Số điện thoại hoặc Email</label>
                        <input class="block w-full px-4 py-3.5 bg-surface-container-low border border-transparent rounded-xl text-on-surface placeholder:text-outline-variant/60 focus:bg-surface-container-lowest focus:border-tertiary-fixed-dim focus:ring-2 focus:ring-tertiary-fixed-dim/30 transition-all font-body-md text-body-md h-[48px] outline-none" id="forgotIdentifier" placeholder="VD: cafe@example.com hoặc 09xxxxxxxx" required type="text"/>
                    </div>

                    <!-- Submit Button -->
                    <button class="w-full py-3.5 px-6 bg-primary-container text-on-primary rounded-xl font-title-lg text-title-lg hover:bg-primary transition-all active:scale-[0.98] shadow-sm flex items-center justify-center gap-2 group mt-2" type="submit">
                        <span>Gửi yêu cầu</span>
                    </button>
                </form>

                <!-- Back to login footer link -->
                <footer class="mt-2 text-center border-t border-outline-variant/30 pt-4">
                    <button type="button" class="inline-flex items-center justify-center gap-2 font-label-md text-label-md text-secondary hover:text-primary transition-colors py-2 px-4 rounded-lg hover:bg-surface-container-low focus:outline-none" onclick="switchPanel('login')">
                        <span>Quay lại đăng nhập</span>
                    </button>
                </footer>
            </div>

        </div>
    </main>
    </div>

    <!-- Footer Copyright -->
    <footer class="w-full text-center relative z-10 py-4 mt-auto">
        <p class="font-label-sm text-label-sm text-outline-variant/80">© 2024 CafePOS. Tất cả quyền được bảo lưu.</p>
    </footer>

    <!-- Form JavaScript Logic -->
    <script>
        const API_URL = "http://localhost:5076/api/v1";

        // Auto redirect if already logged in as Customer
        window.onload = function() {
            const token = localStorage.getItem("token");
            const customerStr = localStorage.getItem("customer");
            const loginMode = localStorage.getItem("loginMode");

            if (token && customerStr && loginMode === "Customer") {
                window.location.href = "/Customer";
            }
        };

        // Smooth panel switching between login, register, and forgot password
        function switchPanel(panelId) {
            document.getElementById("errorAlert").style.display = "none";
            document.getElementById("successAlert").style.display = "none";
            
            const panels = {
                login: document.getElementById("panelLogin"),
                register: document.getElementById("panelRegister"),
                forgot: document.getElementById("panelForgotPassword")
            };

            // Hide all panels with fade/slide out
            for (const key in panels) {
                if (panels[key]) {
                    panels[key].classList.remove("panel-visible");
                    panels[key].classList.add("panel-hidden");
                }
            }

            // Delay showing the destination panel slightly for fluid feel
            setTimeout(() => {
                if (panels[panelId]) {
                    panels[panelId].classList.remove("panel-hidden");
                    panels[panelId].classList.add("panel-visible");
                }
            }, 150);
        }

        // Toggles visibility of password input
        function togglePasswordVisibility(inputId, btnEl) {
            const inputEl = document.getElementById(inputId);
            if (inputEl) {
                const isPassword = inputEl.type === "password";
                inputEl.type = isPassword ? "text" : "password";
                btnEl.textContent = isPassword ? "Ẩn" : "Hiện";
                btnEl.setAttribute("aria-label", isPassword ? "Ẩn mật khẩu" : "Hiện mật khẩu");
            }
        }

        // Display errors
        function showError(msg) {
            const errorAlert = document.getElementById("errorAlert");
            errorAlert.innerText = msg;
            errorAlert.style.display = "block";
            document.getElementById("successAlert").style.display = "none";
            errorAlert.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        // Display success alert
        function showSuccess(msg) {
            const successAlert = document.getElementById("successAlert");
            successAlert.innerText = msg;
            successAlert.style.display = "block";
            document.getElementById("errorAlert").style.display = "none";
            successAlert.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        // Manage overlay displays
        function showOverlay(title, loading = true, isSuccess = false) {
            const overlay = document.getElementById("successOverlay");
            const spinner = document.getElementById("successSpinner");
            const check = document.getElementById("successCheck");
            const titleEl = document.getElementById("successTitle");

            titleEl.innerText = title;
            overlay.classList.remove("opacity-0", "pointer-events-none");
            overlay.classList.add("opacity-100");

            if (loading) {
                spinner.style.display = "block";
                check.classList.add("hidden");
            } else {
                spinner.style.display = "none";
                if (isSuccess) {
                    check.classList.remove("hidden");
                }
            }
        }

        function hideOverlay() {
            const overlay = document.getElementById("successOverlay");
            overlay.classList.remove("opacity-100");
            overlay.classList.add("opacity-0", "pointer-events-none");
        }

        // Submit SĐT / Mật khẩu Login
        async function submitLogin(event) {
            event.preventDefault();
            const phone = document.getElementById("loginPhone").value.trim();
            const password = document.getElementById("loginPassword").value;

            if (!phone || !password) {
                showError("Vui lòng điền đầy đủ số điện thoại và mật khẩu.");
                return;
            }

            showOverlay("Đang đăng nhập...");

            try {
                const response = await fetch(`${API_URL}/auth/customer/login`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ phone: phone, password: password })
                });

                const result = await response.json();

                if (response.ok && result.success) {
                    const data = result.data;
                    localStorage.setItem("token", data.token);
                    localStorage.setItem("customer", JSON.stringify(data.customer));
                    localStorage.setItem("loginMode", "Customer");

                    showOverlay("Đăng nhập thành công!", false, true);

                    setTimeout(() => {
                        window.location.href = "/Customer";
                    }, 1000);
                } else {
                    hideOverlay();
                    showError(result.message || "Đăng nhập thất bại. Vui lòng kiểm tra lại thông tin.");
                }
            } catch (err) {
                hideOverlay();
                showError("Không thể kết nối đến máy chủ API.");
                console.error(err);
            }
        }

        // Submit SĐT Register
        async function submitRegister(event) {
            event.preventDefault();
            const fullName = document.getElementById("regName").value.trim();
            const phone = document.getElementById("regPhone").value.trim();
            const email = document.getElementById("regEmail").value.trim();
            const password = document.getElementById("regPassword").value;
            const confirmPassword = document.getElementById("regConfirmPassword").value;

            if (!fullName || !phone || !email || !password || !confirmPassword) {
                showError("Vui lòng nhập đầy đủ các thông tin đăng ký.");
                return;
            }

            if (password !== confirmPassword) {
                showError("Mật khẩu xác nhận không khớp.");
                return;
            }

            showOverlay("Đang tạo tài khoản...");

            try {
                const response = await fetch(`${API_URL}/auth/customer/register`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        fullName: fullName,
                        phone: phone,
                        email: email,
                        password: password
                    })
                });

                const result = await response.json();

                if (response.ok && result.success) {
                    const data = result.data;
                    localStorage.setItem("token", data.token);
                    localStorage.setItem("customer", JSON.stringify(data.customer));
                    localStorage.setItem("loginMode", "Customer");

                    showOverlay("Đăng ký thành công!", false, true);

                    setTimeout(() => {
                        window.location.href = "/Customer";
                    }, 1000);
                } else {
                    hideOverlay();
                    showError(result.message || "Đăng ký thất bại. Số điện thoại có thể đã tồn tại.");
                }
            } catch (err) {
                hideOverlay();
                showError("Không thể kết nối đến máy chủ API.");
                console.error(err);
            }
        }

        // Forgot Password Mock/Simulated Flow
        async function submitForgotPassword(event) {
            event.preventDefault();
            const identifier = document.getElementById("forgotIdentifier").value.trim();

            if (!identifier) {
                showError("Vui lòng điền số điện thoại hoặc email.");
                return;
            }

            showOverlay("Đang xử lý yêu cầu...");

            // Simulate server network latency
            setTimeout(() => {
                showOverlay("Gửi yêu cầu thành công!", false, true);

                setTimeout(() => {
                    hideOverlay();
                    showSuccess(`Yêu cầu khôi phục đã được gửi! Mã xác nhận/OTP đã được gửi đến: ${identifier}.`);
                    switchPanel('login');
                }, 1500);
            }, 1200);
        }

        // Google Authentication Callback
        async function handleCredentialResponse(googleResponse) {
            const idToken = googleResponse.credential;
            showOverlay("Đang xác thực tài khoản Google...");

            try {
                const response = await fetch(`${API_URL}/auth/customer/google-login`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ idToken: idToken, isDemo: false })
                });

                const result = await response.json();

                if (response.ok && result.success) {
                    const data = result.data;
                    localStorage.setItem("token", data.token);
                    localStorage.setItem("customer", JSON.stringify(data.customer));
                    localStorage.setItem("loginMode", "Customer");

                    showOverlay("Kết nối Google thành công!", false, true);

                    setTimeout(() => {
                        window.location.href = "/Customer";
                    }, 1000);
                } else {
                    hideOverlay();
                    showError(result.message || "Xác thực qua Google thất bại.");
                }
            } catch (err) {
                hideOverlay();
                showError("Không thể kết nối đến máy chủ API.");
                console.error(err);
            }
        }

    </script>
</body>
</html>
